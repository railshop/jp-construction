---
/**
 * ProjectGallery.astro
 * Filterable project showcase grid. Red active filter, red category labels.
 */

import type { Project } from '../../lib/data';

interface Props {
  projects: Project[];
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  showFilter?: boolean;
  showViewAll?: boolean;
  columns?: 2 | 3;
}

const {
  projects,
  eyebrow = 'Portfolio',
  title = 'Our Work',
  subtitle,
  showFilter = true,
  showViewAll = true,
  columns = 3,
} = Astro.props;

const categories = showFilter
  ? ['All', ...Array.from(new Set(projects.map(p => p.category))).filter(Boolean)]
  : [];
---

<section class="section projects-section">
  <div class="container">
    {(eyebrow || title || subtitle) && (
      <header class="projects-header">
        {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
        {title   && <h2 class="section-title">{title}</h2>}
        {subtitle && <p class="section-subtitle">{subtitle}</p>}
      </header>
    )}

    {showFilter && categories.length > 2 && (
      <div class="projects-filter" id="projects-filter" role="group" aria-label="Filter projects by category">
        {categories.map((cat, i) => (
          <button
            class:list={['filter-btn', { 'filter-btn--active': i === 0 }]}
            data-filter={cat === 'All' ? 'all' : cat}
          >
            {cat}
          </button>
        ))}
      </div>
    )}

    <ul
      class:list={['projects-grid', `projects-grid--cols-${columns}`]}
      id="projects-grid"
      role="list"
    >
      {projects.map((project, i) => (
        <li data-category={project.category} class="project-item animate-fade-up" style={`animation-delay:${i * 80}ms`}>
          <a href={`/projects/${project.slug}/`} class="project-card">
            <div class="project-card-image">
              {project.images[0]
                ? <img src={project.images[0]} alt={project.title} loading="lazy" decoding="async" width="600" height="400" />
                : (
                  <div class="project-card-placeholder" aria-hidden="true">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                    <span>Project Photo</span>
                  </div>
                )
              }
              <div class="project-card-overlay">
                <span class="project-card-view">
                  View Project
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </div>
            </div>
            <div class="project-card-body">
              <p class="project-card-category">{project.category}</p>
              <h3 class="project-card-title">{project.title}</h3>
              {project.location && (
                <p class="project-card-location">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  {project.location}
                </p>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>

    {showViewAll && (
      <div class="projects-cta">
        <a href="/projects/" class="btn btn-secondary">View All Projects</a>
      </div>
    )}
  </div>
</section>

<style>
  .projects-header {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-10);
  }

  .projects-header .section-eyebrow {
    justify-content: center;
  }

  .projects-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
    margin-bottom: var(--space-8);
  }

  .filter-btn {
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    background: transparent;
    border: 1.5px solid var(--color-border-strong);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all var(--transition-fast);
    letter-spacing: 0.02em;
  }

  .filter-btn:hover {
    color: var(--color-accent-500);
    border-color: var(--color-accent-500);
  }

  .filter-btn--active {
    background: var(--color-accent-500);
    color: var(--color-text-inverse);
    border-color: var(--color-accent-500);
  }

  .projects-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .projects-grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
  }

  .project-item { opacity: 0; animation-fill-mode: forwards; }
  .project-item.hidden { display: none; }

  .project-card {
    display: block;
    text-decoration: none;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: box-shadow var(--transition-base), transform var(--transition-base), border-color var(--transition-base);
  }

  .project-card:hover {
    box-shadow: 0 12px 40px rgb(0 0 0 / 0.12);
    transform: translateY(-4px);
    border-color: var(--color-accent-500);
  }

  .project-card-image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--color-brand-950);
  }

  .project-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
    display: block;
  }

  .project-card:hover .project-card-image img { transform: scale(1.05); }

  /* Placeholder */
  .project-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    color: rgba(255,255,255,0.2);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 30px 30px;
  }

  /* Overlay */
  .project-card-overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-brand-950) 75%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .project-card:hover .project-card-overlay { opacity: 1; }

  .project-card-view {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: #ffffff;
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-accent-500);
    padding-bottom: 2px;
  }

  .project-card-body {
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg);
  }

  .project-card-category {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent-500);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 var(--space-1);
  }

  .project-card-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    line-height: 1.2;
  }

  .project-card-location {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    margin: 0;
  }

  .projects-cta { text-align: center; margin-top: var(--space-10); }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLLIElement>('.project-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');

      items.forEach(item => {
        const match = filter === 'all' || item.dataset.category === filter;
        item.classList.toggle('hidden', !match);
      });
    });
  });
</script>
