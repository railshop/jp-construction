---
/**
 * Hero.astro
 * Full-width hero. Bold split layout: headline left, project photo right.
 * Designed to breathe — generous vertical space, nothing crammed.
 */

interface Props {
  headline: string;
  subheadline?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  backgroundImage?: string;
  badge?: string;
  trustSignals?: string[];
  variant?: 'default' | 'centered' | 'split';
  googleReviews?: { rating: number; url?: string };
  bbbAccredited?: { url?: string };
  jpOpsCredit?: boolean;
}

const {
  headline,
  subheadline,
  primaryCta = { label: 'Get an Estimate', href: '/contact/' },
  secondaryCta,
  backgroundImage,
  badge,
  trustSignals = [],
  variant = 'default',
  googleReviews,
  bbbAccredited,
  jpOpsCredit,
} = Astro.props;

const hasTrustStrip = !!(googleReviews || bbbAccredited || jpOpsCredit);
---

<section
  class:list={['hero', `hero--${variant}`, { 'hero--bg': !!backgroundImage }, { 'hero--trust-strip': hasTrustStrip }]}
  style={backgroundImage ? `--hero-bg: url('${backgroundImage}')` : ''}
>
  {!backgroundImage && <div class="hero-grid-texture" aria-hidden="true"></div>}
  {backgroundImage && <div class="hero-bg-overlay" aria-hidden="true"></div>}

  <div class="hero-layout">

    <!-- Left: Content -->
    <div class="hero-content">

      <h1 class="hero-headline animate-fade-up" set:html={headline} />

      {subheadline && (
        <p class="hero-subheadline animate-fade-up delay-100">{subheadline}</p>
      )}

      <div class="hero-actions animate-fade-up delay-200">
        <a href={primaryCta.href} class="btn btn-primary btn-lg">
          {primaryCta.label}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn-ghost btn-lg">
            {secondaryCta.label}
          </a>
        )}
      </div>

      {/* Trust signals intentionally moved to hero-trust-strip below. */}
    </div>

    <!-- Right: Image placeholder -->
    <div class="hero-media animate-fade-up delay-100" aria-hidden="true">
      {backgroundImage
        ? <img src={backgroundImage} alt="" class="hero-media-img" loading="eager" />
        : (
          <div class="hero-image-placeholder">
            <div class="hero-image-placeholder-inner">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              <span>Project Photo</span>
            </div>
          </div>
        )
      }
      <div class="hero-media-accent-tr" aria-hidden="true"></div>
      <div class="hero-media-accent-bl" aria-hidden="true"></div>
    </div>

  </div>

  {hasTrustStrip && (
    <div class="hero-trust-strip" role="complementary" aria-label="Trust signals">
      <div class="hts-inner">

        {googleReviews && (
          <a
            href={googleReviews.url || 'https://www.google.com/search?q=jp+operations+north+huntingdon+pa'}
            class="hts-item hts-google"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${googleReviews.rating} out of 5 stars on Google`}
          >
            <span class="hts-logo-circle" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
                <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/>
                <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
                <path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/>
                <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/>
              </svg>
            </span>
            <span class="hts-text-stack">
              <span class="hts-stars" aria-hidden="true">
                {[1,2,3,4,5].map(() => (
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                ))}
              </span>
              <span class="hts-label">Top-Rated on Google</span>
            </span>
          </a>
        )}

        {googleReviews && bbbAccredited && <span class="hts-sep" aria-hidden="true"></span>}

        {bbbAccredited && (
          <a
            href={bbbAccredited.url || 'https://www.bbb.org/us/pa/irwin/profile/excavating-contractors/jp-operations-inc-0141-71023277'}
            class="hts-item hts-bbb"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="BBB Accredited Business"
          >
            <img
              src="/Accredited_Business_Seal_Rating_RGB.svg.svg"
              alt="BBB Accredited Business seal"
              class="hts-bbb-seal"
              loading="eager"
            />
          </a>
        )}

        {(googleReviews || bbbAccredited) && jpOpsCredit && <span class="hts-sep" aria-hidden="true"></span>}

        {jpOpsCredit && (
          <a href="https://www.jpoperations.com/" class="hts-item hts-jpops" target="_blank" rel="noopener noreferrer" aria-label="JP Operations — parent company">
            <span class="hts-jpops-caption">A</span>
            <img
              src="/JP Operations logo white.svg"
              alt="JP Operations"
              class="hts-jpops-logo"
              loading="eager"
            />
            <span class="hts-jpops-caption">Company</span>
          </a>
        )}

      </div>
    </div>
  )}

  <div class="hero-bottom-rule" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--color-brand-950);
    background-image: var(--hero-bg, none);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding-top: calc(var(--header-height) + var(--space-20));
    padding-bottom: var(--space-20);
    overflow: hidden;
    min-height: min(820px, 90vh);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-grid-texture {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 64px 64px;
    pointer-events: none;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      color-mix(in srgb, var(--color-brand-950) 90%, transparent) 55%,
      color-mix(in srgb, var(--color-brand-900) 60%, transparent)
    );
    z-index: 1;
  }

  /* ─── Layout ─────────────────────────────────────────────────────────────── */

  .hero-layout {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  @media (min-width: 640px) { .hero-layout { padding-inline: var(--space-8); } }

  @media (min-width: 1024px) {
    .hero-layout {
      grid-template-columns: 52% 1fr;
      align-items: center;
      gap: var(--space-20);
      padding-inline: var(--space-12);
    }
  }

  /* When a background image is used, single column — no media panel */
  .hero--bg .hero-layout {
    grid-template-columns: 1fr;
  }

  .hero--bg .hero-media {
    display: none !important;
  }

  .hero--bg .hero-subheadline {
    max-width: 620px;
  }

  .hero--bg .hero-headline {
    font-size: clamp(3rem, 6.5vw, 6.5rem);
  }

  /* ─── Content ────────────────────────────────────────────────────────────── */

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-8);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.08;
    color: #ffffff;
    margin: 0;
    letter-spacing: 0;
    text-transform: uppercase; /* h1 — uppercase per Figma spec */
  }

  .hero-headline :global(em) {
    font-style: normal;
    color: #ffffff;
  }

  .hero-subheadline {
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.8;
    max-width: 480px;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  /* ─── Media ──────────────────────────────────────────────────────────────── */

  .hero-media {
    position: relative;
    display: none;
  }

  @media (min-width: 1024px) { .hero-media { display: block; } }

  .hero-media-img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    display: block;
  }

  .hero-image-placeholder {
    width: 100%;
    height: 520px;
    background: var(--color-brand-900);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .hero-image-placeholder-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    color: rgba(255, 255, 255, 0.18);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Red corner brackets */
  .hero-media-accent-tr {
    position: absolute;
    top: -6px;
    right: -6px;
    width: 48px;
    height: 48px;
    border-top: 3px solid var(--color-accent-500);
    border-right: 3px solid var(--color-accent-500);
    border-radius: 0 var(--radius-lg) 0 0;
    pointer-events: none;
  }

  .hero-media-accent-bl {
    position: absolute;
    bottom: -6px;
    left: -6px;
    width: 48px;
    height: 48px;
    border-bottom: 3px solid var(--color-accent-500);
    border-left: 3px solid var(--color-accent-500);
    border-radius: 0 0 0 var(--radius-lg);
    pointer-events: none;
  }

  /* ─── Bottom rule ────────────────────────────────────────────────────────── */

  .hero-bottom-rule {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent-500) 30%, transparent);
  }

  /* ─── Trust Strip ────────────────────────────────────────────────────────── */

  .hero-trust-strip {
    position: absolute;
    bottom: 3px; /* sits flush on top of the red bottom rule */
    left: 0;
    right: 0;
    z-index: 2;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-block: var(--space-3);
  }

  /* Add extra bottom padding to hero so content never overlaps the strip */
  .hero--trust-strip {
    padding-bottom: calc(var(--space-20) + 64px);
  }

  .hts-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    flex-wrap: wrap;
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  @media (min-width: 640px)  { .hts-inner { padding-inline: var(--space-8); } }
  @media (min-width: 1024px) { .hts-inner { padding-inline: var(--space-12); } }

  /* Vertical separator */
  .hts-sep {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
  }

  /* Shared item base */
  .hts-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    transition: opacity var(--transition-fast);
    flex-shrink: 0;
  }

  .hts-item:hover { opacity: 0.75; }

  /* ── Google section ── */
  .hts-logo-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: #ffffff;
    border-radius: 50%;
    flex-shrink: 0;
    padding: 3px;
  }

  .hts-text-stack {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hts-stars {
    display: flex;
    align-items: center;
    gap: 1px;
    color: #FBBF24;
  }

  .hts-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    white-space: nowrap;
    line-height: 1;
  }

  /* ── BBB section ── */
  .hts-bbb-seal {
    height: 38px;
    width: auto;
    display: block;
  }

  /* ── JP Operations section ── */
  .hts-jpops {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .hts-jpops-logo {
    height: 24px;
    width: auto;
    display: block;
  }

  .hts-jpops-caption {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1;
    white-space: nowrap;
  }

  /* Mobile: hide JP Ops on very small screens */
  @media (max-width: 540px) {
    .hts-jpops { display: none; }
    .hts-sep:last-of-type { display: none; }
  }

  /* ─── Centered variant ───────────────────────────────────────────────────── */
  .hero--centered .hero-layout { grid-template-columns: 1fr; }
  .hero--centered .hero-content { align-items: center; max-width: 760px; margin-inline: auto; text-align: center; }
  .hero--centered .hero-subheadline { margin-inline: auto; }
  .hero--centered .hero-trust { justify-content: center; }
  .hero--centered .hero-media { display: none; }
</style>
