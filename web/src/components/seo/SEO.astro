---
/**
 * SEO.astro
 * Handles all head meta tags, JSON-LD structured data, and Open Graph.
 * Every page passes its own seo prop to customize output.
 */

import config from '@/site.config';

export interface SEOProps {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishDate?: string;
  modifiedDate?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  breadcrumbs?: Array<{ name: string; url: string }>;
}

interface Props {
  seo: SEOProps;
}

const { seo } = Astro.props;

const canonical = seo.canonicalURL || Astro.url.href;
const ogImage   = seo.ogImage || `${config.siteUrl}/images/og-default.jpg`;
const fullTitle = `${seo.title} | ${config.siteName}`;

// Build BreadcrumbList schema
const breadcrumbSchema = seo.breadcrumbs && seo.breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: config.siteUrl },
        ...seo.breadcrumbs.map((crumb, i) => ({
          '@type': 'ListItem',
          position: i + 2,
          name: crumb.name,
          item: `${config.siteUrl}${crumb.url}`,
        })),
      ],
    }
  : null;

// Normalize additional schema to array
const schemas: Record<string, unknown>[] = [];
if (seo.schema) {
  if (Array.isArray(seo.schema)) {
    schemas.push(...seo.schema);
  } else {
    schemas.push(seo.schema);
  }
}
if (breadcrumbSchema) schemas.push(breadcrumbSchema);
---

<!-- Primary Meta -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{fullTitle}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={canonical} />
{seo.noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Open Graph -->
<meta property="og:type"        content={seo.ogType || 'website'} />
<meta property="og:url"         content={canonical} />
<meta property="og:title"       content={fullTitle} />
<meta property="og:description" content={seo.description} />
<meta property="og:image"       content={ogImage} />
<meta property="og:site_name"   content={config.siteName} />
{seo.publishDate && <meta property="article:published_time" content={seo.publishDate} />}
{seo.modifiedDate && <meta property="article:modified_time" content={seo.modifiedDate} />}

<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={fullTitle} />
<meta name="twitter:description" content={seo.description} />
<meta name="twitter:image"       content={ogImage} />

<!-- JSON-LD Structured Data -->
{schemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
