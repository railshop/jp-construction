---
/**
 * Footer.astro
 * Site footer with nav links, contact info, hours, and schema markup.
 */

import config from '@/site.config';
import { getBusiness, getServices, getServiceAreas } from '../../lib/data';

const business  = await getBusiness();
const services  = await getServices();
const areas     = await getServiceAreas();
const currentYear  = new Date().getFullYear();
import { homeUrl, aboutUrl, contactUrl, servicesUrl, areasUrl, blogUrl, projectsUrl } from '../../lib/urls';
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        <a href={homeUrl()} class="footer-logo" aria-label={`${business.name} — Home`}>
          <img
            src="/JP%20Construction%20Light%20Trimmed.svg"
            alt={business.name}
            class="footer-logo-img"
            width="206"
            height="40"
            loading="lazy"
          />
        </a>
        <div class="footer-contact">
          <a href={business.phoneHref} class="footer-contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.77 3.44 2 2 0 0 1 3.74 1.26h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {business.phone}
          </a>
          <a href={`mailto:${business.email}`} class="footer-contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            {business.email}
          </a>
          {business.address.street && (
            <a
              href={`https://maps.google.com/?q=${encodeURIComponent(`${business.address.street}, ${business.address.city}, ${business.address.state} ${business.address.zip}`)}`}
              class="footer-contact-link"
              target="_blank"
              rel="noopener"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              {business.address.street}, {business.address.city}, {business.address.state} {business.address.zip}
            </a>
          )}
        </div>

        <!-- Social links -->
        <div class="footer-social">
          <a href="https://www.facebook.com/jpoperationsinc" class="footer-social-link" target="_blank" rel="noopener" aria-label="JP Construction on Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/jpoperations_inc" class="footer-social-link" target="_blank" rel="noopener" aria-label="JP Construction on Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div class="footer-col">
        <h3 class="footer-col-title">Our Services</h3>
        <ul class="footer-links" role="list">
          {services.slice(0, 8).map(service => (
            <li>
              <a href={`/services/${service.slug}/`} class="footer-link">{service.name}</a>
            </li>
          ))}
          {services.length > 8 && (
            <li><a href={servicesUrl()} class="footer-link footer-link--more">View All Services</a></li>
          )}
        </ul>
      </div>

      <!-- Service Areas column -->
      {config.features.serviceAreas && areas.length > 0 && (
        <div class="footer-col">
          <h3 class="footer-col-title">Service Areas</h3>
          <ul class="footer-links" role="list">
            {areas.map(area => (
              <li>
                <a href={`/areas/${area.slug}/`} class="footer-link">{area.name}</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Company column -->
      <div class="footer-col">
        <h3 class="footer-col-title">Company</h3>
        <ul class="footer-links" role="list">
          <li><a href={aboutUrl()} class="footer-link">About Us</a></li>
          {config.features.projects && <li><a href={projectsUrl()} class="footer-link">Our Work</a></li>}
          {config.features.blog && <li><a href={blogUrl()} class="footer-link">Blog</a></li>}
          <li><a href={contactUrl()} class="footer-link">Contact</a></li>
          <li><a href={contactUrl()} class="footer-link">Get an Estimate</a></li>
        </ul>
        {business.license && (
          <p class="footer-license">{business.license}</p>
        )}
      </div>
    </div>

    <!-- Footer bottom -->
    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {currentYear} {business.legalName || business.name}. All rights reserved.
      </p>
      <div class="footer-bottom-right">
        <a href="/privacy/" class="footer-credit-link">Privacy Policy</a>
        <span class="footer-bottom-sep" aria-hidden="true">·</span>
        <p class="footer-credit">
          Website by <a href="https://railshop.co" target="_blank" rel="noopener" class="footer-credit-link">Railshop</a>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-brand-950);
    color: var(--color-neutral-300);
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);

  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; }
  }

  .footer-logo {
    display: block;
    text-decoration: none;
    margin-bottom: var(--space-5);
    transition: opacity var(--transition-fast);
  }

  .footer-logo:hover { opacity: 0.7; }

  .footer-logo-img {
    height: 48px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    color: var(--color-neutral-400);
    margin-bottom: var(--space-5);
    line-height: 1.6;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .footer-contact-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-neutral-300);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-contact-link:hover {
    color: var(--color-accent-400);
  }

  .footer-col-title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-neutral-500);
    margin-bottom: var(--space-4);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-link {
    font-size: var(--text-sm);
    color: var(--color-neutral-400);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover { color: #ffffff; }

  .footer-link--more {
    color: var(--color-accent-400);
    font-weight: 600;
  }

  .footer-link--more:hover { color: var(--color-accent-500); }

  .footer-social {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    color: var(--color-neutral-500);
    border: 1px solid var(--color-neutral-700);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .footer-social-link:hover {
    color: var(--color-accent-400);
    border-color: var(--color-accent-400);
  }

  .footer-license {
    margin-top: var(--space-5);
    font-size: var(--text-xs);
    color: var(--color-neutral-600);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding-top: var(--space-8);
    border-top: 1px solid rgba(255,255,255,0.06);
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer-copy {
    font-size: var(--text-xs);
    color: var(--color-neutral-600);
  }

  .footer-bottom-right {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-neutral-700);
  }

  .footer-bottom-sep {
    font-size: var(--text-xs);
    color: var(--color-neutral-700);
  }

  .footer-credit {
    font-size: var(--text-xs);
    color: var(--color-neutral-700);
    margin: 0;
  }

  .footer-credit-link {
    color: var(--color-neutral-600);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-credit-link:hover { color: var(--color-neutral-400); }
</style>
