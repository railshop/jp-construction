---
/**
 * ProjectGallery.astro
 * Filterable project showcase grid. Supports category filtering.
 */

import type { Project } from '../../lib/data';

interface Props {
  projects: Project[];
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  showFilter?: boolean;
  columns?: 2 | 3;
}

const {
  projects,
  eyebrow = 'Portfolio',
  title = 'Our Work',
  subtitle,
  showFilter = true,
  columns = 3,
} = Astro.props;

const categories = showFilter
  ? ['All', ...Array.from(new Set(projects.map(p => p.category))).filter(Boolean)]
  : [];
---

<section class="section projects-section">
  <div class="container">
    {(eyebrow || title || subtitle) && (
      <header class="section-header" style="text-align:center; max-width:640px; margin-inline:auto; margin-bottom:var(--space-10);">
        {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
        {title   && <h2 class="section-title">{title}</h2>}
        {subtitle && <p class="section-subtitle" style="margin-inline:auto;">{subtitle}</p>}
      </header>
    )}

    {showFilter && categories.length > 2 && (
      <div class="projects-filter" id="projects-filter" role="group" aria-label="Filter projects by category">
        {categories.map((cat, i) => (
          <button
            class:list={['filter-btn', { 'filter-btn--active': i === 0 }]}
            data-filter={cat === 'All' ? 'all' : cat}
          >
            {cat}
          </button>
        ))}
      </div>
    )}

    <ul
      class:list={['projects-grid', `projects-grid--cols-${columns}`]}
      id="projects-grid"
      role="list"
    >
      {projects.map((project, i) => (
        <li data-category={project.category} class="project-item animate-fade-up" style={`animation-delay:${i * 80}ms`}>
          <a href={`/projects/${project.slug}/`} class="project-card">
            <div class="project-card-image">
              {project.images[0]
                ? <img src={project.images[0]} alt={project.title} loading="lazy" decoding="async" width="600" height="400" />
                : <div class="project-card-placeholder" aria-hidden="true"></div>
              }
              <div class="project-card-overlay">
                <span class="project-card-view">View Project</span>
              </div>
            </div>
            <div class="project-card-body">
              <p class="project-card-category">{project.category}</p>
              <h3 class="project-card-title">{project.title}</h3>
              {project.location && (
                <p class="project-card-location">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  {project.location}
                </p>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>

    <div class="projects-cta">
      <a href="/projects/" class="btn btn-secondary">View All Projects</a>
    </div>
  </div>
</section>

<style>
  .projects-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
    margin-bottom: var(--space-8);
  }

  .filter-btn {
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover { color: var(--color-brand-700); border-color: var(--color-brand-300); }

  .filter-btn--active {
    background: var(--color-brand-600);
    color: #ffffff;
    border-color: var(--color-brand-600);
  }

  .projects-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .projects-grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
  }

  .project-item { opacity: 0; animation-fill-mode: forwards; }
  .project-item.hidden { display: none; }

  .project-card {
    display: block;
    text-decoration: none;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .project-card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
  }

  .project-card-image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--color-bg-muted);
  }

  .project-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .project-card:hover .project-card-image img { transform: scale(1.06); }

  .project-card-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-brand-50), var(--color-brand-100));
  }

  .project-card-overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-brand-800) 70%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .project-card:hover .project-card-overlay { opacity: 1; }

  .project-card-view {
    color: #ffffff;
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .project-card-body {
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-top: none;
  }

  .project-card-category {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-brand-600);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--space-1);
  }

  .project-card-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
  }

  .project-card-location {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    margin: 0;
  }

  .projects-cta { text-align: center; margin-top: var(--space-10); }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLLIElement>('.project-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');

      items.forEach(item => {
        const match = filter === 'all' || item.dataset.category === filter;
        item.classList.toggle('hidden', !match);
      });
    });
  });
</script>
