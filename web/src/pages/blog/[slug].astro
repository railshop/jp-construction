---
/**
 * pages/blog/[slug].astro — Individual blog post
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/blocks/CtaBanner.astro';
import RelatedServices from '../../components/blocks/RelatedServices.astro';
import { getBusiness, getBlogPosts, getBlogPostBySlug, getServices } from '../../lib/data';
import { homeUrl, aboutUrl, contactUrl, servicesUrl, areasUrl, blogUrl, projectsUrl, serviceUrl, areaUrl, comboUrl, blogPostUrl, projectUrl } from '../../lib/urls';

export async function getStaticPaths() {
  const { default: config } = await import('@/site.config');
  if (!config.features.blog) return [];
  const posts = await getBlogPosts();
  return posts.map(p => ({ params: { slug: p.slug } }));
}

const { slug }  = Astro.params;
const business  = await getBusiness();
const post      = await getBlogPostBySlug(slug);
const services  = await getServices();

if (!post) return Astro.redirect('/blog/');

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  datePublished: post.publishDate,
  author: { '@type': 'Organization', name: business.name },
  publisher: {
    '@type': 'Organization',
    name: business.name,
    url: import.meta.env.SITE,
  },
  ...(post.image && { image: post.image }),
};
---

<BaseLayout seo={{
  title: post.title,
  description: post.description,
  ogType: 'article',
  publishDate: post.publishDate,
  ogImage: post.image,
  schema: blogSchema,
  breadcrumbs: [
    { name: 'Blog', url: '/blog/' },
    { name: post.title, url: `/blog/${post.slug}/` },
  ],
}}>

  <article class="blog-post">
    <!-- Post header -->
    <header class="post-header">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href={homeUrl()}>Home</a>
          <span aria-hidden="true">/</span>
          <a href={blogUrl()}>Blog</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{post.title}</span>
        </nav>

        <div class="post-meta">
          <span class="blog-category">{post.category}</span>
          <span class="blog-date">
            {new Date(post.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          {post.readingTime && <span class="blog-reading-time">{post.readingTime}</span>}
        </div>

        <h1 class="post-title">{post.title}</h1>
        <p class="post-description">{post.description}</p>

        <div class="post-byline">
          <span class="post-author">By {post.author || business.name}</span>
        </div>
      </div>

      {post.image && (
        <div class="post-hero-image">
          <div class="container">
            <img src={post.image} alt={post.title} loading="eager" width="1200" height="630" />
          </div>
        </div>
      )}
    </header>

    <!-- Post body -->
    <div class="post-body">
      <div class="container">
        <div class="post-layout">
          <div class="post-content prose" set:html={post.body} />

          <!-- Sidebar -->
          <aside class="post-sidebar">
            <div class="post-sidebar-cta">
              <h3>Get an Estimate</h3>
              <p>Ready to get started? Contact {business.name} today.</p>
              <a href={contactUrl()} class="btn btn-primary" style="width:100%; justify-content:center;">Request a Quote</a>
              <a href={business.phoneHref} class="btn btn-ghost" style="width:100%; justify-content:center; margin-top:var(--space-3);">
                {business.phone}
              </a>
            </div>

            {post.tags && post.tags.length > 0 && (
              <div class="post-tags">
                <h4 class="post-tags-title">Tags</h4>
                <div class="post-tags-list">
                  {post.tags.map(tag => (
                    <span class="badge badge-neutral">{tag}</span>
                  ))}
                </div>
              </div>
            )}
          </aside>
        </div>
      </div>
    </div>
  </article>

  <RelatedServices services={services} title="Our Services" />

  <CtaBanner
    headline="Ready to Get Started?"
    subheadline={`Contact ${business.name} for your free estimate.`}
    primaryCta={{ label: 'Get an Estimate', href: '/contact/' }}
    phone={business.phone}
    phoneHref={business.phoneHref}
    variant="brand"
  />
</BaseLayout>

<style>
  .post-header { padding-block: var(--space-12) var(--space-8); background: var(--color-bg-subtle); border-bottom: 1px solid var(--color-border); }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-6);
  }

  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-brand-600); }

  .post-meta { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3); margin-bottom: var(--space-5); }

  .blog-category {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-brand-600);
    background: var(--color-brand-50);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .blog-date, .blog-reading-time { font-size: var(--text-sm); color: var(--color-text-subtle); }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 var(--space-4);
    max-width: 800px;
  }

  .post-description {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 var(--space-5);
    max-width: 720px;
  }

  .post-byline { font-size: var(--text-sm); color: var(--color-text-muted); }
  .post-author { font-weight: 600; }

  .post-hero-image { margin-top: var(--space-8); }
  .post-hero-image img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }

  .post-body { padding-block: var(--space-12); }

  .post-layout {
    display: grid;
    gap: var(--space-12);
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .post-layout { grid-template-columns: 1fr 280px; align-items: start; }
  }

  .post-sidebar { display: flex; flex-direction: column; gap: var(--space-6); }

  .post-sidebar-cta {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    position: sticky;
    top: calc(var(--header-height) + var(--space-8));
    text-align: center;
  }

  .post-sidebar-cta h3 { font-family: var(--font-display); font-size: var(--text-xl); margin: 0 0 var(--space-2); }
  .post-sidebar-cta p  { font-size: var(--text-sm); color: var(--color-text-muted); margin: 0 0 var(--space-5); }

  .post-tags-title {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }

  .post-tags-list { display: flex; flex-wrap: wrap; gap: var(--space-2); }
</style>
