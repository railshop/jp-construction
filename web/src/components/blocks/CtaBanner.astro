---
/**
 * CtaBanner.astro
 * High-converting CTA section. Use mid-page and at page bottom.
 */

interface Props {
  headline?: string;
  subheadline?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  variant?: 'brand' | 'dark' | 'accent';
  phone?: string;
  phoneHref?: string;
}

const {
  headline = 'Ready to Get Started?',
  subheadline = 'Get your free quote today. No obligation, no pressure.',
  primaryCta = { label: 'Get a Free Quote', href: '/contact/' },
  secondaryCta,
  variant = 'brand',
  phone,
  phoneHref,
} = Astro.props;
---

<section class:list={['cta-banner', `cta-banner--${variant}`]}>
  <div class="container">
    <div class="cta-banner-inner">
      <div class="cta-banner-text">
        <h2 class="cta-banner-headline">{headline}</h2>
        {subheadline && <p class="cta-banner-sub">{subheadline}</p>}
      </div>
      <div class="cta-banner-actions">
        <a href={primaryCta.href} class:list={['btn btn-lg', variant === 'accent' ? 'btn-primary' : 'btn-accent']}>
          {primaryCta.label}
        </a>
        {phone && phoneHref && (
          <a href={phoneHref} class="btn btn-ghost btn-lg cta-phone-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.77 3.44 2 2 0 0 1 3.74 1.26h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {phone}
          </a>
        )}
        {secondaryCta && !phone && (
          <a href={secondaryCta.href} class="btn btn-ghost btn-lg">{secondaryCta.label}</a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    padding-block: var(--space-16);
  }

  .cta-banner--brand  { background: var(--color-brand-600); }
  .cta-banner--dark   { background: var(--color-neutral-900); }
  .cta-banner--accent { background: var(--color-accent-500); }

  .cta-banner-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    align-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .cta-banner-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .cta-banner-text { flex: 1; }

  .cta-banner-headline {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 var(--space-2);
  }

  .cta-banner--accent .cta-banner-headline { color: var(--color-neutral-900); }

  .cta-banner-sub {
    font-size: var(--text-base);
    color: color-mix(in srgb, #ffffff 80%, transparent);
    margin: 0;
  }

  .cta-banner--accent .cta-banner-sub { color: var(--color-neutral-700); }

  .cta-banner-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .cta-phone-btn {
    color: #ffffff;
    border-color: color-mix(in srgb, #ffffff 40%, transparent);
  }

  .cta-phone-btn:hover {
    background: color-mix(in srgb, #ffffff 10%, transparent);
    border-color: #ffffff;
  }
</style>
