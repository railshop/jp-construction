---
/**
 * StickyPhoneBar.astro
 * Fixed bottom bar on mobile with click-to-call and quote CTA.
 * Hidden on desktop. Hidden when contact form is visible.
 */

import { getBusiness } from '../../lib/data';

const business = await getBusiness();
---

<div class="sticky-phone-bar" id="sticky-phone-bar" aria-label="Contact bar">
  <a href={business.phoneHref} class="sticky-phone-btn sticky-phone-btn--call">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.77 3.44 2 2 0 0 1 3.74 1.26h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
    <span>Call Now</span>
  </a>
  <a href="/contact/" class="sticky-phone-btn sticky-phone-btn--quote">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
    </svg>
    <span>Free Quote</span>
  </a>
</div>

<style>
  .sticky-phone-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    display: flex;
    height: 64px;
    box-shadow: 0 -4px 16px rgb(0 0 0 / 0.15);
    transform: translateY(0);
    transition: transform var(--transition-base);
  }

  @media (min-width: 1024px) {
    .sticky-phone-bar { display: none; }
  }

  .sticky-phone-bar.hidden {
    transform: translateY(100%);
  }

  .sticky-phone-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: filter var(--transition-fast);
  }

  .sticky-phone-btn:active { filter: brightness(0.9); }

  .sticky-phone-btn--call {
    background: var(--color-brand-600);
    color: #ffffff;
  }

  .sticky-phone-btn--quote {
    background: var(--color-neutral-900);
    color: #ffffff;
  }
</style>

<script>
  // Hide bar when contact form is in viewport
  const bar = document.getElementById('sticky-phone-bar');
  const form = document.querySelector('form[name="contact"]');

  if (bar && form) {
    const observer = new IntersectionObserver(
      ([entry]) => bar.classList.toggle('hidden', entry.isIntersecting),
      { threshold: 0.3 }
    );
    observer.observe(form);
  }
</script>
