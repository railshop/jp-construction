---
/**
 * pages/areas/index.astro — Service areas listing
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/blocks/CtaBanner.astro';
import { getBusiness, getServiceAreas, getServices } from '../../lib/data';
import { contactUrl, servicesUrl } from '../../lib/urls';

const business = await getBusiness();
const areas    = await getServiceAreas();
const services = await getServices();

const primary   = areas.filter(a => a.priority === 'primary');
const secondary = areas.filter(a => a.priority === 'secondary');
const tertiary  = areas.filter(a => a.priority === 'tertiary');
---

<BaseLayout seo={{
  title: `Service Areas — ${business.address.city} and Surrounding Communities`,
  description: `${business.name} serves ${business.serviceRadius || business.address.city + ' and surrounding areas'}. View all areas we cover and response times.`,
  breadcrumbs: [{ name: 'Service Areas', url: '/areas/' }],
}}>

  <div class="page-hero">
    <div class="container">
      <p class="section-eyebrow">Where We Work</p>
      <h1 class="section-title">Same Crew.<br/>Wherever You Are.</h1>
      <p class="section-subtitle">
        Based in North Huntingdon, we cover Westmoreland County and the surrounding region. Wherever you are, you get the same crew, the same standards, and the same accountability.
      </p>
      <div class="hero-actions">
        <a href={contactUrl()} class="btn btn-primary btn-lg">Get an Estimate</a>
        <a href={servicesUrl()} class="btn btn-ghost-light btn-lg">View Our Services</a>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {primary.length > 0 && (
        <div class="areas-group">
          <h2 class="areas-group-title">Primary Service Area</h2>
          <ul class="areas-grid" role="list">
            {primary.map(area => (
              <li>
                <a href={`/areas/${area.slug}/`} class="area-card area-card--primary">
                  <div class="area-card-body">
                    <h3 class="area-card-name">{area.name}</h3>
                    {area.county && <p class="area-card-county">{area.county}</p>}
                    {area.responseTime && (
                      <p class="area-card-response">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <circle cx="12" cy="12" r="10"/>
                          <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        {area.responseTime} response
                      </p>
                    )}
                  </div>
                  <svg class="area-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {secondary.length > 0 && (
        <div class="areas-group">
          <h2 class="areas-group-title">Extended Service Area</h2>
          <ul class="areas-grid" role="list">
            {secondary.map(area => (
              <li>
                <a href={`/areas/${area.slug}/`} class="area-card">
                  <div class="area-card-body">
                    <h3 class="area-card-name">{area.name}</h3>
                    {area.county && <p class="area-card-county">{area.county}</p>}
                    {area.responseTime && (
                      <p class="area-card-response">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <circle cx="12" cy="12" r="10"/>
                          <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        {area.responseTime} response
                      </p>
                    )}
                  </div>
                  <svg class="area-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {tertiary.length > 0 && (
        <div class="areas-group">
          <h2 class="areas-group-title">Additional Coverage</h2>
          <ul class="areas-pills" role="list">
            {tertiary.map(area => (
              <li>
                <a href={`/areas/${area.slug}/`} class="area-pill">{area.name}</a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  <!-- Services available in every area -->
  <section class="services-strip section">
    <div class="container">
      <div class="services-strip-header">
        <div>
          <p class="section-eyebrow">What We Do</p>
          <h2 class="services-strip-title">Every Service, Every Area</h2>
          <p class="services-strip-sub">Wherever you are in our coverage area, you get our full range of services — the same crew, the same standards, and the same commitment to getting it right.</p>
        </div>
        <a href="/services/" class="services-strip-link">
          View all services
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
      <ul class="service-tiles" role="list">
        {services.map(service => (
          <li>
            <a href={`/services/${service.slug}/`} class="service-tile">
              <span class="service-tile-name">{service.name}</span>
              <span class="service-tile-desc">{service.shortDescription}</span>
              <span class="service-tile-cta">
                Learn more
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CtaBanner
    headline="Don't See Your Area?"
    subheadline="Give us a call. We may still be able to serve you."
    primaryCta={{ label: 'Contact Us', href: '/contact/' }}
    phone={business.phone}
    phoneHref={business.phoneHref}
    variant="dark"
  />
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: var(--space-24) 0 var(--space-20);
    background-color: var(--color-brand-900);
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1487958449943-2429e8be8625?w=1600&q=80&auto=format&fit=crop');
    background-size: cover;
    background-position: center 60%;
  }

  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(10,10,10,0.82) 0%, rgba(10,10,10,0.60) 60%, rgba(10,10,10,0.40) 100%),
      linear-gradient(to top, rgba(10,10,10,0.50) 0%, transparent 50%);
  }

  .page-hero .container {
    position: relative;
    z-index: 1;
  }

  .page-hero .section-eyebrow { color: var(--color-accent-500); }
  .page-hero .section-title { color: #ffffff; margin-top: var(--space-2); }
  .page-hero .section-subtitle { color: rgba(255, 255, 255, 0.72); margin-top: var(--space-3); max-width: 560px; }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .btn-ghost-light {
    color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.30);
    background: transparent;
  }

  .btn-ghost-light:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.08);
  }

  .areas-group { margin-bottom: var(--space-12); }

  .areas-group-title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-5);
  }

  .areas-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px)  { .areas-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .areas-grid { grid-template-columns: repeat(3, 1fr); } }

  .area-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .area-card:hover {
    border-color: var(--color-brand-300);
    box-shadow: var(--shadow-md);
    transform: translateX(4px);
  }

  .area-card--primary { border-left: 3px solid var(--color-accent-500); }

  .area-card-name   { font-weight: 700; color: var(--color-text); margin: 0 0 var(--space-1); font-size: var(--text-base); }
  .area-card-county { font-size: var(--text-xs); color: var(--color-text-muted); margin: 0 0 var(--space-1); }

  .area-card-response {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--color-brand-600);
    font-weight: 500;
    margin: 0;
  }

  .area-card-arrow { color: var(--color-text-subtle); flex-shrink: 0; transition: transform var(--transition-fast); }
  .area-card:hover .area-card-arrow { transform: translateX(4px); color: var(--color-brand-600); }

  .areas-pills {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .area-pill {
    display: inline-flex;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .area-pill:hover {
    color: var(--color-brand-700);
    background: var(--color-brand-50);
    border-color: var(--color-brand-300);
  }

  /* ── Services strip ─────────────────────────────────────────────────────── */
  .services-strip {
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .services-strip-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
  }

  .services-strip-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
    font-weight: 700;
    color: var(--color-text);
    margin: var(--space-1) 0 var(--space-2);
    line-height: 1.2;
  }

  .services-strip-sub {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: 480px;
    line-height: 1.6;
    margin: 0;
  }

  .services-strip-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent-500);
    text-decoration: none;
    white-space: nowrap;
    margin-top: var(--space-2);
    transition: gap 0.15s ease;
    flex-shrink: 0;
  }

  .services-strip-link:hover { gap: var(--space-2); }

  .service-tiles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px)  { .service-tiles { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .service-tiles { grid-template-columns: repeat(3, 1fr); } }

  .service-tile {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5) var(--space-6);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .service-tile:hover {
    border-color: var(--color-accent-500);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .service-tile-name {
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.3;
  }

  .service-tile-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.55;
    flex: 1;
  }

  .service-tile-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent-500);
    margin-top: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    letter-spacing: 0.01em;
    transition: gap 0.15s ease;
  }

  .service-tile:hover .service-tile-cta { gap: var(--space-2); }
</style>
