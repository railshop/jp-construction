---
/**
 * pages/areas/[area].astro — Individual service area page
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCardsGrid from '../../components/blocks/ServiceCardsGrid.astro';
import Testimonials from '../../components/blocks/Testimonials.astro';
import FaqAccordion from '../../components/blocks/FaqAccordion.astro';
import CtaBanner from '../../components/blocks/CtaBanner.astro';
import RelatedServices from '../../components/blocks/RelatedServices.astro';
import { getBusiness, getServiceAreas, getServices, getTestimonials, getFaqs } from '../../lib/data';
import config from '@/site.config';

export async function getStaticPaths() {
  const areas = await getServiceAreas();
  return areas.map(a => ({ params: { area: a.slug } }));
}

const { area: areaSlug }  = Astro.params;
const business     = await getBusiness();
const areas        = await getServiceAreas();
const services     = await getServices();
const testimonials = await getTestimonials();
const faqs         = await getFaqs();

const area           = areas.find(a => a.slug === areaSlug)!;
const otherAreas     = areas.filter(a => a.slug !== areaSlug);
const primaryAreas   = otherAreas.filter(a => a.priority === 'primary');
const secondaryAreas = otherAreas.filter(a => a.priority === 'secondary');

const areaTestimonials = testimonials.filter(t =>
  !t.area || (t.area as unknown as string) === areaSlug
).slice(0, 3);

const localSchema = {
  '@context': 'https://schema.org',
  '@type': config.schemaType,
  name: business.name,
  description: `${business.name} provides professional services in ${area.name}, ${area.county || business.address.state}.`,
  telephone: business.phone,
  url: `${config.siteUrl}/areas/${area.slug}/`,
  areaServed: {
    '@type': 'City',
    name: area.name,
    ...(area.county && { containedInPlace: { '@type': 'AdministrativeArea', name: area.county } }),
  },
};
import { homeUrl, aboutUrl, contactUrl, servicesUrl, areasUrl, blogUrl, projectsUrl, serviceUrl, areaUrl, comboUrl, blogPostUrl, projectUrl } from '../../lib/urls';
---

<BaseLayout seo={{
  title: `${business.name} in ${area.name}, ${area.county || business.address.state}`,
  description: `${business.name} serves ${area.name}${area.county ? ', ' + area.county : ''}. Professional, licensed service with ${area.responseTime || 'fast'} response times. Free estimates.`,
  schema: localSchema,
  breadcrumbs: [
    { name: 'Service Areas', url: '/areas/' },
    { name: area.name, url: `/areas/${area.slug}/` },
  ],
}}>

  <!-- Area hero -->
  <div class="area-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={homeUrl()}>Home</a>
        <span aria-hidden="true">/</span>
        <a href={areasUrl()}>Service Areas</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{area.name}</span>
      </nav>

      <p class="section-eyebrow">{area.county || 'Service Area'}</p>
      <h1 class="area-hero-title">Construction Services in {area.name}, {business.address.state}</h1>
      {area.description && (
        <p class="area-hero-desc">{area.description}</p>
      )}

      <div class="area-hero-actions">
        <a href={contactUrl()} class="btn btn-primary btn-lg">Get an Estimate</a>
        <a href={business.phoneHref} class="btn btn-ghost btn-lg">{business.phone}</a>
      </div>
    </div>
  </div>

  <!-- Services in this area -->
  <ServiceCardsGrid
    services={services}
    eyebrow={`Services in ${area.name}`}
    title={`What We Offer in ${area.name}`}
    subtitle={`The full range of ${business.name} services, available to homes and businesses in ${area.name}.`}
    areaSlug={areaSlug}
    showViewAll={false}
  />

  <!-- FAQ -->
  {faqs.length > 0 && (
    <FaqAccordion
      faqs={faqs}
      eyebrow="FAQ"
      title={`Common Questions from ${area.name} Customers`}
      variant="dark"
    />
  )}

  <!-- Testimonials -->
  {areaTestimonials.length > 0 && (
    <Testimonials
      testimonials={areaTestimonials}
      businessName={business.name}
      eyebrow="Local Reviews"
      title={`What ${area.name} Customers Say`}
    />
  )}

  <!-- Other service areas -->
  {otherAreas.length > 0 && (
    <section class="nearby-section">
      <div class="container">
        <div class="nearby-header">
          <div>
            <p class="section-eyebrow">Where We Work</p>
            <h2 class="nearby-title">Other Areas We Serve</h2>
          </div>
          <a href="/areas/" class="nearby-all-link">
            View all areas
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>

        <ul class="nearby-grid" role="list">
          {primaryAreas.map(nearby => (
            <li>
              <a href={`/areas/${nearby.slug}/`} class="nearby-card nearby-card--primary">
                <div class="nearby-card-body">
                  <span class="nearby-card-name">{nearby.name}</span>
                  {nearby.responseTime && (
                    <span class="nearby-card-response">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                      </svg>
                      {nearby.responseTime}
                    </span>
                  )}
                </div>
                <svg class="nearby-card-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>

        {secondaryAreas.length > 0 && (
          <div class="nearby-secondary-row">
            <span class="nearby-secondary-label">Also serving:</span>
            <ul class="nearby-pills" role="list">
              {secondaryAreas.map(nearby => (
                <li>
                  <a href={`/areas/${nearby.slug}/`} class="nearby-pill">{nearby.name}</a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  <CtaBanner
    headline={`Need Service in ${area.name}?`}
    subheadline={`We're ${area.responseTime ? area.responseTime + ' away' : 'nearby'}. Call or request a free quote online.`}
    primaryCta={{ label: 'Get an Estimate', href: '/contact/' }}
    phone={business.phone}
    phoneHref={business.phoneHref}
    variant="brand"
  />
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .area-hero {
    padding: var(--space-24) 0 var(--space-20);
    background: linear-gradient(160deg, var(--color-brand-900) 0%, var(--color-brand-950) 100%);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-neutral-400);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .breadcrumb a { color: var(--color-neutral-400); text-decoration: none; }
  .breadcrumb a:hover { color: #ffffff; }
  .breadcrumb span[aria-hidden] { color: var(--color-neutral-600); }

  .area-hero .section-eyebrow { color: var(--color-accent-500); }

  .area-hero-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    color: #ffffff;
    margin: var(--space-2) 0 var(--space-4);
    max-width: 900px;
  }

  .area-hero-desc {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    margin: 0 0 var(--space-6);
    max-width: 640px;
  }

  .area-hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-4); margin-top: var(--space-8); }

  .area-hero-actions .btn-ghost {
    color: #ffffff;
    border-color: var(--color-neutral-500);
  }

  .area-hero-actions .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--color-neutral-300);
  }

  /* ── Other areas ──────────────────────────────────────────────────────────── */
  .nearby-section {
    padding: var(--space-16) 0;
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .nearby-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .nearby-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
    font-weight: 700;
    color: var(--color-text);
    margin: var(--space-1) 0 0;
    line-height: 1.2;
  }

  .nearby-all-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent-500);
    text-decoration: none;
    white-space: nowrap;
    transition: gap 0.15s ease;
  }

  .nearby-all-link:hover { gap: var(--space-2); }

  .nearby-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  @media (min-width: 640px)  { .nearby-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .nearby-grid { grid-template-columns: repeat(4, 1fr); } }

  .nearby-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .nearby-card:hover {
    border-color: var(--color-brand-300);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    transform: translateX(3px);
  }

  .nearby-card--primary { border-left: 3px solid var(--color-accent-500); }

  .nearby-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .nearby-card-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .nearby-card-response {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .nearby-card-arrow {
    flex-shrink: 0;
    color: var(--color-text-subtle);
    transition: color 0.15s ease, transform 0.15s ease;
  }

  .nearby-card:hover .nearby-card-arrow {
    color: var(--color-brand-600);
    transform: translateX(2px);
  }

  .nearby-secondary-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-6);
    flex-wrap: wrap;
  }

  .nearby-secondary-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .nearby-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nearby-pill {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .nearby-pill:hover {
    border-color: var(--color-brand-300);
    color: var(--color-brand-700);
  }
</style>
