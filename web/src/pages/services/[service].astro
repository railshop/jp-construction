---
/**
 * pages/services/[service].astro — Individual service page
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProcessSteps from '../../components/blocks/ProcessSteps.astro';
import Testimonials from '../../components/blocks/Testimonials.astro';
import FaqAccordion from '../../components/blocks/FaqAccordion.astro';
import RelatedServices from '../../components/blocks/RelatedServices.astro';
import SeoServiceAreas from '../../components/seo/SeoServiceAreas.astro';
import CtaBanner from '../../components/blocks/CtaBanner.astro';
import { getBusiness, getServices, getTestimonials, getFaqs } from '../../lib/data';
import config from '@/site.config';

export async function getStaticPaths() {
  const services = await getServices();
  return services.map(s => ({ params: { service: s.slug } }));
}

const { service: serviceSlug } = Astro.params;
const business     = await getBusiness();
const services     = await getServices();
const service      = services.find(s => s.slug === serviceSlug)!;
const testimonials = await getTestimonials();
const faqs         = await getFaqs();

const serviceTestimonials = testimonials.filter(t =>
  !t.service || t.service === serviceSlug
).slice(0, 3);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.name,
  description: service.description,
  provider: {
    '@type': config.schemaType,
    name: business.name,
    telephone: business.phone,
    url: config.siteUrl,
  },
  areaServed: {
    '@type': 'City',
    name: business.address.city,
  },
  ...(service.priceRange && {
    offers: {
      '@type': 'Offer',
      priceRange: `$${service.priceRange.min} - $${service.priceRange.max}`,
      priceCurrency: 'USD',
    },
  }),
};
import { homeUrl, aboutUrl, contactUrl, servicesUrl, areasUrl, blogUrl, projectsUrl, serviceUrl, areaUrl, comboUrl, blogPostUrl, projectUrl } from '../../lib/urls';
---

<BaseLayout seo={{
  title: service.name,
  description: `${service.shortDescription} Serving ${business.address.city} and surrounding areas. Licensed, insured, free estimates.`,
  ogType: 'website',
  schema: serviceSchema,
  breadcrumbs: [
    { name: 'Services', url: '/services/' },
    { name: service.name, url: `/services/${service.slug}/` },
  ],
}}>

  <!-- Service hero -->
  <div class="service-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={homeUrl()}>Home</a>
        <span aria-hidden="true">/</span>
        <a href={servicesUrl()}>Services</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{service.name}</span>
      </nav>
      <p class="section-eyebrow">Our Services</p>
      {service.emergency && (
        <span class="badge badge-accent" style="display:inline-flex;margin-bottom:var(--space-4)">24/7 Emergency Service</span>
      )}
      <h1 class="section-title">{service.name}</h1>
      <p class="service-hero-sub">
        {service.heroTagline || `Licensed general contractor serving ${business.address.city} and ${business.serviceRadius || 'the surrounding area'}. Fully insured. Free estimates on every project.`}
      </p>
      <div class="hero-actions">
        <a href={contactUrl()} class="btn btn-primary btn-lg">Get an Estimate</a>
        <a href={business.phoneHref} class="btn btn-ghost btn-lg">{business.phone}</a>
      </div>
    </div>
  </div>

  <!-- Service intro -->
  <section class="service-intro section">
    <div class="container">
      <div class="service-intro-grid">
        <div class="service-intro-text">
          <p class="section-eyebrow">What We Do</p>
          <h2 class="service-intro-heading">{service.shortDescription}</h2>
          <p class="service-intro-desc">{service.description}</p>
        </div>
        <div class="service-intro-image">
          {service.image
            ? <img src={service.image} alt={`${service.name} by ${business.name}`} loading="lazy" />
            : <div class="service-intro-image-fallback" aria-hidden="true"></div>
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Process steps -->
  {service.processSteps?.length > 0 && (
    <ProcessSteps
      steps={service.processSteps}
      eyebrow="Our Process"
      title={`How We Handle ${service.name}`}
    />
  )}

  <!-- FAQ -->
  {faqs.length > 0 && (
    <FaqAccordion
      faqs={faqs}
      eyebrow="FAQ"
      title={`${service.name} Questions Answered`}
      variant="dark"
    />
  )}

  <!-- Testimonials -->
  {serviceTestimonials.length > 0 && (
    <Testimonials
      testimonials={serviceTestimonials}
      businessName={business.name}
      eyebrow="Reviews"
      title={`What Customers Say About Our ${service.name}`}
    />
  )}

  <!-- All areas for this service -->
  <SeoServiceAreas
    service={service}
    areas={await (async () => { const { getServiceAreas } = await import('../../lib/data'); return getServiceAreas(); })()}
    title="Areas We Serve"
  />

  <!-- Related services -->
  <RelatedServices services={services} currentSlug={service.slug} />

  <!-- CTA -->
  <CtaBanner
    headline={`Need ${service.name} in ${business.address.city}?`}
    subheadline={`Call us or request a free quote online. We respond quickly.`}
    primaryCta={{ label: 'Get an Estimate', href: '/contact/' }}
    phone={business.phone}
    phoneHref={business.phoneHref}
    variant="brand"
  />
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .service-hero {
    padding: var(--space-24) 0 var(--space-20);
    background: linear-gradient(160deg, var(--color-brand-900) 0%, var(--color-brand-950) 100%);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-neutral-400);
    margin-bottom: var(--space-8);
  }

  .breadcrumb a { color: var(--color-neutral-400); text-decoration: none; }
  .breadcrumb a:hover { color: #ffffff; }
  .breadcrumb span[aria-hidden] { color: var(--color-neutral-600); }

  .service-hero .section-eyebrow { color: var(--color-accent-500); }

  .service-hero .section-title {
    color: #ffffff;
    margin-top: var(--space-2);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    max-width: 900px;
  }

  .service-hero-sub {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    max-width: 600px;
    margin: var(--space-4) 0 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .service-hero .btn-ghost {
    color: #ffffff;
    border-color: var(--color-neutral-500);
  }

  .service-hero .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--color-neutral-300);
  }

  /* ── Service intro ────────────────────────────────────────────────────────── */
  .service-intro {
    border-bottom: 1px solid var(--color-border);
  }

  .service-intro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 768px) {
    .service-intro-grid {
      grid-template-columns: 55fr 45fr;
      gap: var(--space-16);
    }
  }

  .service-intro-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .service-intro-heading {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-text);
    margin: var(--space-3) 0 var(--space-5);
  }

  .service-intro-desc {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .service-intro-image {
    position: relative;
    min-height: 400px;
    border-radius: var(--radius-2xl);
    overflow: hidden;
  }

  .service-intro-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .service-intro-image-fallback {
    position: absolute;
    inset: 0;
    background: var(--color-brand-800);
  }
</style>
