---
/**
 * CtaBanner.astro
 * High-converting CTA section. Dark industrial treatment with red primary button.
 */

interface Props {
  headline?: string;
  subheadline?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  variant?: 'brand' | 'dark' | 'accent';
  phone?: string;
  phoneHref?: string;
}

const {
  headline = 'Ready to Get Started?',
  subheadline = 'Get your free quote today. No obligation, no pressure.',
  primaryCta = { label: 'Get an Estimate', href: '/contact/' },
  secondaryCta,
  variant = 'brand',
  phone,
  phoneHref,
} = Astro.props;
---

<section class:list={['cta-banner', `cta-banner--${variant}`]}>
  <div class="cta-banner-texture" aria-hidden="true"></div>
  <div class="cta-banner-accent-bar" aria-hidden="true"></div>
  <div class="container">
    <div class="cta-banner-inner">
      <div class="cta-banner-text">
        <h2 class="cta-banner-headline">{headline}</h2>
        {subheadline && <p class="cta-banner-sub">{subheadline}</p>}
      </div>
      <div class="cta-banner-actions">
        <a href={primaryCta.href} class="btn btn-primary btn-lg">
          {primaryCta.label}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        {phone && phoneHref && (
          <a href={phoneHref} class="btn btn-ghost btn-lg cta-phone-btn">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.77 3.44 2 2 0 0 1 3.74 1.26h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {phone}
          </a>
        )}
        {secondaryCta && !phone && (
          <a href={secondaryCta.href} class="btn btn-ghost btn-lg">{secondaryCta.label}</a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    padding-block: var(--space-20);
    position: relative;
    overflow: hidden;
  }

  .cta-banner-texture {
    display: none;
  }

  .cta-banner-accent-bar {
    display: none;
  }

  .cta-banner--brand  { background: var(--color-brand-900); }
  .cta-banner--dark   { background: var(--color-brand-950); }
  .cta-banner--accent {
    background: var(--color-accent-500);
  }

  /* On accent variant, texture is different */
  .cta-banner--accent .cta-banner-texture {
    background-image:
      linear-gradient(rgba(0,0,0,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,0,0,0.06) 1px, transparent 1px);
  }

  .cta-banner--accent .cta-banner-accent-bar {
    background: rgba(0,0,0,0.2);
  }

  .cta-banner-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    align-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .cta-banner-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
      gap: var(--space-16);
    }
  }

  .cta-banner-text { flex: 1; }

  .cta-banner-headline {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 var(--space-2);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .cta-banner--accent .cta-banner-headline { color: #ffffff; }

  .cta-banner-sub {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: 1.65;
  }

  .cta-banner--accent .cta-banner-sub { color: rgba(255,255,255,0.85); }

  .cta-banner-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .cta-banner-actions {
      justify-content: flex-start;
    }
  }

  /* Override ghost button for the phone CTA */
  .cta-phone-btn {
    color: rgba(255,255,255,0.75);
    border-color: rgba(255,255,255,0.25);
  }

  .cta-phone-btn:hover {
    color: #ffffff;
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.5);
  }

  /* On accent variant, btn-primary should be white */
  .cta-banner--accent :global(.btn-primary) {
    background-color: #ffffff;
    color: var(--color-neutral-900);
    border-color: #ffffff;
  }

  .cta-banner--accent :global(.btn-primary:hover) {
    background-color: var(--color-neutral-100);
    border-color: var(--color-neutral-100);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }
</style>
