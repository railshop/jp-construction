---
/**
 * pages/projects/index.astro — Projects showcase listing
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectGallery from '../../components/blocks/ProjectGallery.astro';
import CtaBanner from '../../components/blocks/CtaBanner.astro';
import { getBusiness, getProjects } from '../../lib/data';
import { contactUrl, servicesUrl } from '../../lib/urls';

const business = await getBusiness();
const projects = await getProjects();
---

<BaseLayout seo={{
  title: `Our Work — Projects & Portfolio`,
  description: `Browse completed projects by ${business.name}. Real work, real results for homeowners and businesses in ${business.address.city} and surrounding areas.`,
  breadcrumbs: [{ name: 'Projects', url: '/projects/' }],
}}>

  <div class="page-hero">
    <div class="container">
      <p class="section-eyebrow">Portfolio</p>
      <h1 class="section-title">Real Work.<br/>Real Results.</h1>
      <p class="section-subtitle">
        Every project shown here was built and managed by JP Construction from first site visit to final walkthrough. The work speaks for itself.
      </p>
      <div class="hero-actions">
        <a href={contactUrl()} class="btn btn-primary btn-lg">Start Your Project</a>
        <a href={servicesUrl()} class="btn btn-ghost-light btn-lg">View Our Services</a>
      </div>
    </div>
  </div>

  {projects.length === 0
    ? (
      <section class="section">
        <div class="container" style="text-align:center; color:var(--color-text-muted); padding-block:var(--space-20);">
          <p>Projects coming soon. Check back shortly.</p>
        </div>
      </section>
    )
    : (
      <ProjectGallery
        projects={projects}
        showFilter={true}
        showViewAll={false}
        columns={3}
      />
    )
  }

  <CtaBanner
    headline="Like What You See?"
    subheadline="Get in touch for a free estimate on your project."
    primaryCta={{ label: 'Start Your Project', href: '/contact/' }}
    phone={business.phone}
    phoneHref={business.phoneHref}
    variant="brand"
  />
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: var(--space-24) 0 var(--space-20);
    background-color: var(--color-brand-900);
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=1600&q=80&auto=format&fit=crop');
    background-size: cover;
    background-position: center 55%;
  }

  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(10,10,10,0.82) 0%, rgba(10,10,10,0.60) 60%, rgba(10,10,10,0.40) 100%),
      linear-gradient(to top, rgba(10,10,10,0.50) 0%, transparent 50%);
  }

  .page-hero .container {
    position: relative;
    z-index: 1;
  }

  .page-hero .section-eyebrow { color: var(--color-accent-500); }
  .page-hero .section-title { color: #ffffff; margin-top: var(--space-2); }
  .page-hero .section-subtitle { color: rgba(255, 255, 255, 0.72); margin-top: var(--space-3); max-width: 560px; }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .btn-ghost-light {
    color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.30);
    background: transparent;
  }

  .btn-ghost-light:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.08);
  }
</style>
