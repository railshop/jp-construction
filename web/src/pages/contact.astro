---
/**
 * pages/contact.astro — Contact page with Netlify Forms
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { getBusiness, getServices } from '../lib/data';
import config from '@/site.config';

const business = await getBusiness();
const services = await getServices();
---

<BaseLayout seo={{
  title: 'Get an Estimate | Contact JP Construction',
  description: `Contact ${business.name} for a free estimate. Serving ${business.address.city} and surrounding areas. Call ${business.phone} or fill out our quick form.`,
  breadcrumbs: [{ name: 'Contact', url: '/contact/' }],
}}>

  <div class="contact-page">
    <div class="container">
      <div class="contact-grid">

        <!-- Info Column -->
        <aside class="contact-info-col">
          <p class="section-eyebrow">Get in Touch</p>
          <h1 class="section-title contact-page-title">Let's Build<br/>Something.</h1>
          <p class="section-subtitle">
            Describe your project and we'll reach out to schedule a site visit and estimate. No pressure. No obligation.
          </p>

          <div class="contact-details">
            <a href={business.phoneHref} class="contact-detail-item contact-detail-link">
              <svg class="contact-detail-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.77 3.44 2 2 0 0 1 3.74 1.26h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <div>
                <p class="contact-detail-label">Call Us</p>
                <p class="contact-detail-value">{business.phone}</p>
              </div>
            </a>

            <a href={`mailto:${business.email}`} class="contact-detail-item contact-detail-link">
              <svg class="contact-detail-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <div>
                <p class="contact-detail-label">Email Us</p>
                <p class="contact-detail-value">{business.email}</p>
              </div>
            </a>

            {business.address.street && (
              <a
                href={`https://maps.google.com/?q=${encodeURIComponent(`${business.address.street}, ${business.address.city}, ${business.address.state} ${business.address.zip}`)}`}
                class="contact-detail-item contact-detail-link"
                target="_blank"
                rel="noopener"
              >
                <svg class="contact-detail-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <div>
                  <p class="contact-detail-label">Address</p>
                  <p class="contact-detail-value">{business.address.street}<br/>{business.address.city}, {business.address.state} {business.address.zip}</p>
                </div>
              </a>
            )}

            {business.address.city && (
              <div class="contact-detail-item">
                <svg class="contact-detail-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <div>
                  <p class="contact-detail-label">Service Area</p>
                  <p class="contact-detail-value">{business.serviceRadius || `${business.address.city}, ${business.address.state}`}</p>
                </div>
              </div>
            )}
          </div>

          {business.license && (
            <p class="contact-license">{business.license} &bull; Fully Insured</p>
          )}
        </aside>

        <!-- Form Column -->
        <div class="contact-form-col">
          <!-- Netlify Form -->
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="contact-form"
            id="contact-form"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="contact-honeypot" aria-hidden="true">
              <label>Do not fill this out: <input name="bot-field" /></label>
            </p>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="first-name">First Name <span class="form-required" aria-label="required">*</span></label>
                <input class="form-input" type="text" id="first-name" name="first-name" required autocomplete="given-name" />
              </div>
              <div class="form-group">
                <label class="form-label" for="last-name">Last Name <span class="form-required" aria-label="required">*</span></label>
                <input class="form-input" type="text" id="last-name" name="last-name" required autocomplete="family-name" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="email">Email <span class="form-required" aria-label="required">*</span></label>
                <input class="form-input" type="email" id="email" name="email" required autocomplete="email" />
              </div>
              <div class="form-group">
                <label class="form-label" for="phone">Phone <span class="form-required" aria-label="required">*</span></label>
                <input class="form-input" type="tel" id="phone" name="phone" required autocomplete="tel" pattern="[\+]?[(]?[0-9]{3}[)]?[-\s\.]?[0-9]{3}[-\s\.]?[0-9]{4}" title="Please enter a valid US phone number" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="service">Service Needed</label>
              <select class="form-select" id="service" name="service">
                <option value="">Select a service...</option>
                {services.map(s => (
                  <option value={s.slug}>{s.name}</option>
                ))}
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="message">Tell Us About Your Project <span class="form-required" aria-label="required">*</span></label>
              <textarea
                class="form-textarea"
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Describe your project, timeline, and any specific requirements..."
              ></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="address">Property Address <span class="form-optional">(Optional)</span></label>
              <input class="form-input" type="text" id="address" name="address" autocomplete="street-address" placeholder="123 Main St, City, State" data-places-autocomplete />
            </div>

            <div class="form-submit-row">
              <button type="submit" class="btn btn-primary btn-lg form-submit-btn">
                Send My Request
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </button>
            </div>
          </form>

          <div class="form-success hidden" id="form-success" role="status" aria-live="polite">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <h2>Thank You!</h2>
            <p>We received your request and will follow up within one business day.</p>
          </div>
        </div>

      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .contact-page {
    padding-block: var(--space-16);
  }

  .contact-grid {
    display: grid;
    gap: var(--space-16);
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: 420px 1fr;
      align-items: start;
    }
  }

  /* ── Info Column ──────────────────────────────────────────────────────────── */

  .contact-info-col {
    position: relative;
  }

  @media (min-width: 1024px) {
    .contact-info-col {
      position: sticky;
      top: calc(var(--header-height) + var(--space-8));
    }
  }

  .contact-page-title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    margin-bottom: var(--space-4);
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .contact-detail-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .contact-detail-link {
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .contact-detail-link:hover .contact-detail-value {
    color: var(--color-accent-500);
  }

  .contact-detail-icon {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-accent-500);
  }

  .contact-detail-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-1);
  }

  .contact-detail-value {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
    transition: color var(--transition-fast);
  }

  .contact-license {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    margin: var(--space-5) 0 0;
  }

  /* ── Form Column ──────────────────────────────────────────────────────────── */

  .contact-form-col {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
  }

  @media (min-width: 640px) {
    .contact-form-col {
      padding: var(--space-10);
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .form-row {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 560px) {
    .form-row { grid-template-columns: 1fr 1fr; }
  }

  .form-required { color: var(--color-accent-500); }

  .form-optional {
    font-weight: 400;
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
  }

  .contact-honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .form-submit-row {
    margin-top: var(--space-2);
  }

  /* ── Success State ────────────────────────────────────────────────────────── */

  .hidden { display: none !important; }

  .form-success {
    text-align: center;
    padding: var(--space-12);
    background: var(--color-brand-50);
    border: 1px solid var(--color-brand-200);
    border-radius: var(--radius-xl);
    color: var(--color-brand-700);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .form-success h2 { color: var(--color-brand-800); margin: 0; }
  .form-success p  { color: var(--color-brand-700); margin: 0; }
</style>

{config.googleMapsApiKey && (
  <script
    src={`https://maps.googleapis.com/maps/api/js?key=${config.googleMapsApiKey}&libraries=places`}
    async
    defer
  ></script>
)}

<script>
  // Basic client-side success state after Netlify submission
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  if (form && success) {
    if (window.location.search.includes('success=true')) {
      form.classList.add('hidden');
      success.classList.remove('hidden');
    }
  }

  // Google Places Autocomplete on address field
  const addressInput = document.querySelector<HTMLInputElement>('[data-places-autocomplete]');
  if (addressInput && typeof google !== 'undefined' && google.maps?.places) {
    const autocomplete = new google.maps.places.Autocomplete(addressInput, {
      types: ['address'],
      componentRestrictions: { country: 'us' },
      fields: ['formatted_address'],
    });
    autocomplete.addListener('place_changed', () => {
      const place = autocomplete.getPlace();
      if (place.formatted_address) {
        addressInput.value = place.formatted_address;
      }
    });
  }
</script>
