---
/**
 * pages/services/[area]/[service].astro
 *
 * Combo pages — one unique page for every service × area combination.
 * 
 * With 8 services and 10 areas this generates 80 additional indexed pages,
 * each targeting a specific "service in city" search query with content
 * that is locally aware rather than templated.
 *
 * Content quality is driven by area.localContext in the data layer.
 * The richer that context, the more genuinely unique the copy on each page.
 * Claude Code should populate localContext when setting up a new client.
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProcessSteps from '../../../components/blocks/ProcessSteps.astro';
import Testimonials from '../../../components/blocks/Testimonials.astro';
import FaqAccordion from '../../../components/blocks/FaqAccordion.astro';
import RelatedServices from '../../../components/blocks/RelatedServices.astro';
import CtaBanner from '../../../components/blocks/CtaBanner.astro';
import StatsBar from '../../../components/blocks/StatsBar.astro';

import {
  getBusiness,
  getServices,
  getServiceAreas,
  getTestimonials,
  generateComboContent,
  generateComboFaqs,
} from '../../../lib/data';
import SeoServiceAreas from '../../../components/seo/SeoServiceAreas.astro';
import config from '../../../site.config';

export async function getStaticPaths() {
  const services = await getServices();
  const areas    = await getServiceAreas();

  // Generate every service × area combination
  return services.flatMap(service =>
    areas.map(area => ({
      params: { area: area.slug, service: service.slug },
    }))
  );
}

const { area: areaSlug, service: serviceSlug } = Astro.params;

const business     = await getBusiness();
const services     = await getServices();
const areas        = await getServiceAreas();
const service      = services.find(s => s.slug === serviceSlug)!;
const area         = areas.find(a => a.slug === areaSlug)!;
const allTestimonials = await getTestimonials();

// Filter testimonials to this area or service first, then fall back to featured
const relevantTestimonials = allTestimonials
  .filter(t => (t.area as unknown as string) === areaSlug || (t.service as unknown as string) === serviceSlug)
  .slice(0, 3);
const testimonials = relevantTestimonials.length >= 2
  ? relevantTestimonials
  : allTestimonials.filter(t => t.featured).slice(0, 3);

// Nearby areas from the same area data
const nearbyAreas = area.nearby
  ? areas.filter(a => (area.nearby as string[]).includes(a.slug)).slice(0, 5)
  : [];

// Generate locally-aware content
const content  = generateComboContent(service, area, business);
const comboFaqs = generateComboFaqs(service, area, business);

const years = business.yearEstablished
  ? new Date().getFullYear() - business.yearEstablished
  : null;

// JSON-LD — LocalBusiness scoped to this city + Service
const comboSchema = [
  {
    '@context': 'https://schema.org',
    '@type': config.schemaType,
    name: business.name,
    description: content.metaDescription,
    telephone: business.phone,
    url: `${config.siteUrl}/services/${area.slug}/${service.slug}/`,
    areaServed: {
      '@type': 'City',
      name: area.name,
      ...(area.county && { containedInPlace: { '@type': 'AdministrativeArea', name: area.county } }),
    },
    ...(area.lat && area.lng && {
      geo: { '@type': 'GeoCoordinates', latitude: area.lat, longitude: area.lng },
    }),
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: `${service.name} in ${area.name}`,
      itemListElement: [{
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: service.name,
          description: service.shortDescription,
          areaServed: { '@type': 'City', name: area.name },
          ...(service.priceRange && {
            offers: {
              '@type': 'Offer',
              priceRange: `$${service.priceRange.min} - $${service.priceRange.max}`,
              priceCurrency: 'USD',
            },
          }),
        },
      }],
    },
  },
  // FAQPage schema using generated combo FAQs
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: comboFaqs.map(faq => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  },
];
import { homeUrl, aboutUrl, contactUrl, servicesUrl, areasUrl, blogUrl, projectsUrl, serviceUrl, areaUrl, comboUrl, blogPostUrl, projectUrl } from '../../../lib/urls';
---

<BaseLayout seo={{
  title: content.ogTitle,
  description: content.metaDescription,
  schema: comboSchema,
  breadcrumbs: [
    { name: 'Services', url: '/services/' },
    { name: area.name, url: `/areas/${area.slug}/` },
    { name: service.name, url: `/services/${area.slug}/${service.slug}/` },
  ],
}}>

  <!-- Combo hero -->
  <div class="combo-hero">
    {service.image && (
      <div class="combo-hero-bg" aria-hidden="true">
        <img src={service.image} alt="" width="1280" height="520" />
        <div class="combo-hero-overlay"></div>
      </div>
    )}

    <div class="container combo-hero-content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={homeUrl()}>Home</a>
        <span aria-hidden="true">/</span>
        <a href={servicesUrl()}>Services</a>
        <span aria-hidden="true">/</span>
        <a href={`/areas/${area.slug}/`}>{area.name}</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{service.name}</span>
      </nav>

      <div class="combo-hero-grid">
        <div class="combo-hero-text">
          <!-- Area + service badge -->
          <div class="combo-badges">
            <span class="badge badge-brand">{area.name}</span>
            {service.emergency && <span class="badge badge-accent">24/7 Emergency</span>}
          </div>

          <h1 class="combo-headline">{content.headline}</h1>
          <p class="combo-subheadline">{content.subheadline}</p>
          <p class="combo-description">{content.heroDescription}</p>

          <div class="combo-hero-actions">
            <a href={contactUrl()} class="btn btn-primary btn-lg">Get a Free Quote</a>
            <a href={business.phoneHref} class="btn btn-ghost btn-lg">{business.phone}</a>
          </div>

          <!-- Local why-us strip -->
          <p class="combo-why-us">{content.whyUsLocal}</p>
        </div>

        <!-- Sidebar quick facts -->
        <aside class="combo-sidebar">
          <div class="combo-sidebar-card">
            <h2 class="combo-sidebar-title">Service Details</h2>

            <div class="combo-fact">
              <span class="combo-fact-label">Location</span>
              <span class="combo-fact-value">{area.name}{area.county ? `, ${area.county}` : ''}</span>
            </div>

            {area.responseTime && (
              <div class="combo-fact">
                <span class="combo-fact-label">Response Time</span>
                <span class="combo-fact-value combo-fact-highlight">{area.responseTime}</span>
              </div>
            )}

            {service.priceRange && (
              <div class="combo-fact">
                <span class="combo-fact-label">Typical Range</span>
                <span class="combo-fact-value">${service.priceRange.min.toLocaleString()} – ${service.priceRange.max.toLocaleString()}</span>
              </div>
            )}

            <div class="combo-fact">
              <span class="combo-fact-label">Availability</span>
              <span class="combo-fact-value">{service.emergency ? '24/7 Emergency' : 'By Appointment'}</span>
            </div>

            {business.license && (
              <div class="combo-fact">
                <span class="combo-fact-label">License</span>
                <span class="combo-fact-value">{business.license}</span>
              </div>
            )}

            <a href={contactUrl()} class="btn btn-primary" style="width:100%; justify-content:center; margin-top:var(--space-5);">
              Schedule Service
            </a>
            <a href={business.phoneHref} class="btn btn-ghost" style="width:100%; justify-content:center; margin-top:var(--space-3);">
              {business.phone}
            </a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <!-- Local angle section -->
  {area.localContext && (
    <section class="section-sm local-angle-section">
      <div class="container">
        <div class="local-angle-grid">
          <div class="local-angle-content">
            <p class="section-eyebrow">Why Local Matters</p>
            <h2 class="local-angle-title">
              {service.name} Built for {area.name} Properties
            </h2>
            <p class="local-angle-body">{content.localAngle}</p>

            {area.localContext.commonChallenges && area.localContext.commonChallenges.length > 0 && (
              <div class="local-challenges">
                <p class="local-challenges-label">Common local challenges we address:</p>
                <ul class="local-challenges-list" role="list">
                  {area.localContext.commonChallenges.map(challenge => (
                    <li class="local-challenge-item">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      {challenge}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>

          {area.localContext.notableFeatures && area.localContext.notableFeatures.length > 0 && (
            <div class="local-features">
              <p class="local-features-label">Area characteristics</p>
              <ul class="local-features-list" role="list">
                {area.localContext.notableFeatures.map(feature => (
                  <li class="badge badge-neutral local-feature-badge">{feature}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Stats -->
  {years && (
    <StatsBar stats={[
      { value: `${years}+`, label: 'Years Serving the Area' },
      { value: '1,000+', label: 'Projects Completed' },
      { value: '5★', label: 'Average Rating' },
      { value: area.responseTime || 'Fast', label: 'Response to ' + area.name },
    ]} />
  )}

  <!-- Process steps -->
  {service.processSteps?.length > 0 && (
    <ProcessSteps
      steps={service.processSteps}
      eyebrow={`Our ${area.name} Process`}
      title={`How We Handle ${service.name} in ${area.name}`}
      subtitle={content.processIntro}
    />
  )}

  <!-- Testimonials -->
  {testimonials.length > 0 && (
    <Testimonials
      testimonials={testimonials}
      businessName={business.name}
      eyebrow="Local Reviews"
      title={`What ${area.name} Customers Say`}
    />
  )}

  <!-- Combo FAQs -->
  <FaqAccordion
    faqs={comboFaqs}
    eyebrow="FAQ"
    title={`${service.name} in ${area.name} — Common Questions`}
    subtitle={content.faqIntro}
    includeSchema={false}
  />

  <!-- Nearby areas for same service — strong internal link signal -->
  {nearbyAreas.length > 0 && (
    <section class="section-sm nearby-combo-section">
      <div class="container">
        <h2 class="nearby-combo-title">
          {service.name} Near {area.name}
        </h2>
        <p class="nearby-combo-subtitle">
          We also provide {service.name.toLowerCase()} in these nearby communities:
        </p>
        <ul class="nearby-combo-list" role="list">
          {nearbyAreas.map(nearby => (
            <li>
              <a href={`/services/${nearby.slug}/${service.slug}/`} class="nearby-combo-link">
                {service.name} in {nearby.name}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>

        <!-- Also link back to the area's main page and service's main page -->
        <div class="combo-crosslinks">
          <a href={`/areas/${area.slug}/`} class="crosslink">
            All services in {area.name} →
          </a>
          <a href={`/services/${service.slug}/`} class="crosslink">
            {service.name} across all areas →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- All areas for this service — internal link mesh -->
  <SeoServiceAreas
    service={service}
    areas={areas}
    currentAreaSlug={areaSlug}
  />

  <!-- Related services -->
  <RelatedServices
    services={services}
    currentSlug={service.slug}
    title={`Other Services in ${area.name}`}
  />

  <!-- Final CTA -->
  <CtaBanner
    headline={content.ctaHeadline}
    subheadline={`Licensed, insured, and ${area.responseTime ? area.responseTime + ' away' : 'local to ' + area.name}. Get your free estimate today.`}
    primaryCta={{ label: 'Get a Free Quote', href: '/contact/' }}
    phone={business.phone}
    phoneHref={business.phoneHref}
    variant="brand"
  />
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .combo-hero {
    position: relative;
    background: var(--color-neutral-900);
    padding: var(--space-10) 0 var(--space-14);
  }

  .combo-hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .combo-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .combo-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      color-mix(in srgb, var(--color-neutral-950) 88%, transparent),
      color-mix(in srgb, var(--color-neutral-950) 55%, transparent)
    );
  }

  .combo-hero-content { position: relative; z-index: 1; }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .breadcrumb a { color: var(--color-neutral-400); text-decoration: none; }
  .breadcrumb a:hover { color: #ffffff; }

  .combo-hero-grid {
    display: grid;
    gap: var(--space-10);
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .combo-hero-grid { grid-template-columns: 1fr 320px; align-items: start; }
  }

  .combo-badges {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .combo-headline {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    margin: 0 0 var(--space-3);
  }

  .combo-subheadline {
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-brand-300);
    margin: 0 0 var(--space-4);
    line-height: 1.4;
  }

  .combo-description {
    font-size: var(--text-lg);
    color: var(--color-neutral-300);
    line-height: 1.7;
    margin: 0 0 var(--space-6);
    max-width: 580px;
  }

  .combo-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .combo-hero-actions .btn-ghost {
    color: #ffffff;
    border-color: var(--color-neutral-500);
  }

  .combo-why-us {
    font-size: var(--text-sm);
    color: var(--color-neutral-400);
    margin: 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-neutral-800);
  }

  /* ── Sidebar ──────────────────────────────────────────────────────────────── */
  .combo-sidebar-card {
    background: var(--color-bg);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: var(--shadow-xl);
  }

  .combo-sidebar-title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-5);
  }

  .combo-fact {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-sm);
  }

  .combo-fact:last-of-type { border-bottom: none; }
  .combo-fact-label { color: var(--color-text-muted); flex-shrink: 0; }
  .combo-fact-value { font-weight: 600; color: var(--color-text); text-align: right; }
  .combo-fact-highlight { color: var(--color-brand-700); }

  /* ── Local angle ─────────────────────────────────────────────────────────── */
  .local-angle-section { background: var(--color-bg-subtle); border-bottom: 1px solid var(--color-border); }

  .local-angle-grid {
    display: grid;
    gap: var(--space-10);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .local-angle-grid { grid-template-columns: 1fr auto; align-items: start; }
  }

  .local-angle-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
    font-weight: 700;
    margin: var(--space-2) 0 var(--space-4);
  }

  .local-angle-body {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .local-challenges { margin-top: var(--space-5); }

  .local-challenges-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }

  .local-challenges-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .local-challenge-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .local-challenge-item svg { color: var(--color-brand-600); flex-shrink: 0; }

  .local-features { min-width: 200px; }

  .local-features-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }

  .local-features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .local-feature-badge { justify-content: flex-start; }

  /* ── Nearby combos ───────────────────────────────────────────────────────── */
  .nearby-combo-section {
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
  }

  .nearby-combo-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    margin: 0 0 var(--space-2);
  }

  .nearby-combo-subtitle {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-5);
  }

  .nearby-combo-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-6);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .nearby-combo-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-brand-700);
    background: var(--color-brand-50);
    border: 1px solid var(--color-brand-200);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .nearby-combo-link:hover {
    background: var(--color-brand-100);
    border-color: var(--color-brand-400);
  }

  .combo-crosslinks {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-8);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .crosslink {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-brand-600);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .crosslink:hover { color: var(--color-brand-800); }
</style>
