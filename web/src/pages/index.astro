---
/**
 * pages/index.astro — Homepage
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/blocks/Hero.astro';
import TrustBar from '../components/blocks/TrustBar.astro';
import ServiceCardsGrid from '../components/blocks/ServiceCardsGrid.astro';
import FeaturedProjects from '../components/blocks/FeaturedProjects.astro';
import Testimonials from '../components/blocks/Testimonials.astro';
import FaqAccordion from '../components/blocks/FaqAccordion.astro';
import CtaBanner from '../components/blocks/CtaBanner.astro';
import GoogleMapsEmbed from '../components/blocks/GoogleMapsEmbed.astro';
import EmergencyBanner from '../components/blocks/EmergencyBanner.astro';

import {
  getBusiness, getServices, getProjects,
  getTestimonials, getFaqs, getServiceAreas,
} from '../lib/data';
import config from '@/site.config';

const business     = await getBusiness();
const services     = await getServices();
const projects     = await getProjects(6);
const testimonials = await getTestimonials(3);
const faqs         = await getFaqs();
const serviceAreas = await getServiceAreas();

const _yearsInBusiness = business.yearEstablished
  ? new Date().getFullYear() - business.yearEstablished
  : null;

// LocalBusiness JSON-LD schema
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': config.schemaType,
  name: business.name,
  legalName: business.legalName,
  url: config.siteUrl,
  telephone: business.phone,
  email: business.email,
  description: business.description,
  ...(business.address && {
    address: {
      '@type': 'PostalAddress',
      streetAddress: business.address.street,
      addressLocality: business.address.city,
      addressRegion: business.address.state,
      postalCode: business.address.zip,
      addressCountry: 'US',
    },
  }),
  ...(business.coordinates && {
    geo: {
      '@type': 'GeoCoordinates',
      latitude: business.coordinates.lat,
      longitude: business.coordinates.lng,
    },
  }),
  openingHoursSpecification: business.hours.map(h => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.days,
    opens: '00:00',
    closes: '23:59',
  })),
  ...(business.yearEstablished && { foundingDate: String(business.yearEstablished) }),
  ...(business.logo && { logo: business.logo }),
  ...(serviceAreas.length > 0 && {
    areaServed: serviceAreas.map(a => ({
      '@type': 'City',
      name: a.name,
      containedInPlace: { '@type': 'State', name: 'Pennsylvania' },
    })),
  }),
  ...(business.coordinates && {
    hasMap: `https://maps.google.com/maps?q=${business.coordinates.lat},${business.coordinates.lng}`,
  }),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `${business.name} Services`,
    itemListElement: services.slice(0, 10).map(s => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.name,
        description: s.shortDescription,
      },
    })),
  },
};
---

<BaseLayout
  seo={{
    title: `${business.name} — ${business.address.city}, ${business.address.state}`,
    description: business.description,
    schema: localBusinessSchema,
  }}
  fullWidthHero
>
  {config.features.emergencyBanner && <EmergencyBanner />}

  <Hero
    headline={`<em>Built Right.<br>Built to Last.</em>`}
    subheadline={business.description}
    primaryCta={{ label: 'Get an Estimate', href: '/contact/' }}
    secondaryCta={{ label: 'View Our Work', href: '/projects/' }}
    backgroundImage="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=1800&q=85&auto=format&fit=crop"
    googleReviews={{ rating: 4.9 }}
    bbbAccredited={{}}
    jpOpsCredit={true}
  />


  <style>
    .trust-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: var(--text-sm);
      font-weight: 600;
      color: var(--color-text-muted);
      letter-spacing: 0.01em;
    }
    .trust-item svg { color: var(--color-accent-500); flex-shrink: 0; }
  </style>

  <!-- Services -->
  <ServiceCardsGrid
    services={services}
    eyebrow="What We Do"
    title={`${business.address.city}'s Trusted ${config.schemaType.replace(/([A-Z])/g, ' $1').trim()} Services`}
    subtitle={`Professional, reliable service from a team that takes pride in every job.`}
  />

  <!-- Featured Projects -->
  {config.features.projects && projects.length > 0 && (
    <FeaturedProjects
      projects={projects}
      eyebrow="Our Work"
      title="Built to Show For"
      subtitle={`Real projects, real results from across Westmoreland County.`}
    />
  )}

  <!-- Testimonials -->
  {testimonials.length > 0 && (
    <Testimonials
      testimonials={testimonials}
      businessName={business.name}
      eyebrow="Reviews"
      title="What Our Customers Say"
    />
  )}

  <!-- FAQ -->
  {faqs.length > 0 && (
    <FaqAccordion
      faqs={faqs}
      eyebrow="FAQ"
      title="Common Questions"
    />
  )}

  <!-- Map -->
  <GoogleMapsEmbed serviceAreas={serviceAreas} />

  <!-- Final CTA -->
  <CtaBanner
    headline="Let's Get Started"
    subheadline={`Serving ${business.serviceRadius || business.address.city}. Get your free estimate today.`}
    primaryCta={{ label: 'Contact Us Today', href: '/contact/' }}
    phone={business.phone}
    phoneHref={business.phoneHref}
    variant="dark"
  />
</BaseLayout>
