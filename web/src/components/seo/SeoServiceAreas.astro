---
/**
 * SeoServiceAreas.astro
 *
 * Renders a grid of all service areas for a given service.
 * Used at the bottom of combo pages (/services/[area]/[service]/)
 * and individual service pages to surface the full coverage map.
 *
 * Strong internal linking signal — connects every combo page to every
 * other combo page for the same service, creating a tight link mesh
 * that search engines can fully crawl.
 */

import type { ServiceArea, Service } from '../../lib/data';
import { comboUrl, areaUrl } from '../../lib/urls';

interface Props {
  service: Service;
  areas: ServiceArea[];
  currentAreaSlug?: string;
  title?: string;
  showResponseTime?: boolean;
}

const {
  service,
  areas,
  currentAreaSlug,
  title,
  showResponseTime = true,
} = Astro.props;

// Exclude the current area, group by priority
const otherAreas = areas.filter(a => a.slug !== currentAreaSlug);
const primary   = otherAreas.filter(a => a.priority === 'primary');
const secondary = otherAreas.filter(a => a.priority === 'secondary');
const tertiary  = otherAreas.filter(a => a.priority === 'tertiary');

const displayTitle = title || `${service.name} in Every Area We Serve`;
---

{otherAreas.length > 0 && (
  <section class="seo-service-areas section-sm">
    <div class="container">
      <div class="ssa-header">
        <h2 class="ssa-title">{displayTitle}</h2>
        <p class="ssa-subtitle">
          We provide {service.name.toLowerCase()} across the entire service area.
          Select your community for specific pricing, availability, and local details.
        </p>
      </div>

      {primary.length > 0 && (
        <div class="ssa-group">
          <p class="ssa-group-label">Primary Service Area</p>
          <ul class="ssa-grid ssa-grid--primary" role="list">
            {primary.map(area => (
              <li>
                <a href={comboUrl(area.slug, service.slug)} class="ssa-card ssa-card--primary">
                  <div class="ssa-card-body">
                    <span class="ssa-area-name">{area.name}</span>
                    {area.county && <span class="ssa-county">{area.county}</span>}
                    {showResponseTime && area.responseTime && (
                      <span class="ssa-response">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <circle cx="12" cy="12" r="10"/>
                          <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        {area.responseTime}
                      </span>
                    )}
                  </div>
                  <svg class="ssa-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {secondary.length > 0 && (
        <div class="ssa-group">
          <p class="ssa-group-label">Extended Coverage</p>
          <ul class="ssa-grid" role="list">
            {secondary.map(area => (
              <li>
                <a href={comboUrl(area.slug, service.slug)} class="ssa-card">
                  <div class="ssa-card-body">
                    <span class="ssa-area-name">{area.name}</span>
                    {area.county && <span class="ssa-county">{area.county}</span>}
                    {showResponseTime && area.responseTime && (
                      <span class="ssa-response">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <circle cx="12" cy="12" r="10"/>
                          <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        {area.responseTime}
                      </span>
                    )}
                  </div>
                  <svg class="ssa-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {tertiary.length > 0 && (
        <div class="ssa-group">
          <p class="ssa-group-label">Additional Areas</p>
          <ul class="ssa-pills" role="list">
            {tertiary.map(area => (
              <li>
                <a href={comboUrl(area.slug, service.slug)} class="ssa-pill">
                  {area.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Link back to main service page -->
      <div class="ssa-footer">
        <a href={`/services/${service.slug}/`} class="ssa-back-link">
          ← View all {service.name} details
        </a>
      </div>
    </div>
  </section>
)}

<style>
  .seo-service-areas {
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
  }

  .ssa-header {
    margin-bottom: var(--space-8);
  }

  .ssa-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-2xl));
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
  }

  .ssa-subtitle {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    max-width: 560px;
  }

  .ssa-group {
    margin-bottom: var(--space-8);
  }

  .ssa-group-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-3);
  }

  /* Grid */
  .ssa-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-2);
    grid-template-columns: 1fr;
  }

  @media (min-width: 480px)  { .ssa-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 768px)  { .ssa-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .ssa-grid { grid-template-columns: repeat(4, 1fr); } }

  @media (min-width: 768px)  { .ssa-grid--primary { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .ssa-grid--primary { grid-template-columns: repeat(3, 1fr); } }

  /* Cards */
  .ssa-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .ssa-card:hover {
    border-color: var(--color-brand-300);
    box-shadow: var(--shadow-sm);
    transform: translateX(3px);
  }

  .ssa-card--primary {
    border-left: 3px solid var(--color-brand-400);
  }

  .ssa-card-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .ssa-area-name {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ssa-county {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .ssa-response {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: var(--text-xs);
    color: var(--color-brand-600);
    font-weight: 500;
  }

  .ssa-arrow {
    color: var(--color-text-subtle);
    flex-shrink: 0;
    transition: transform var(--transition-fast), color var(--transition-fast);
  }

  .ssa-card:hover .ssa-arrow {
    transform: translateX(3px);
    color: var(--color-brand-600);
  }

  /* Pills for tertiary */
  .ssa-pills {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .ssa-pill {
    display: inline-flex;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .ssa-pill:hover {
    color: var(--color-brand-700);
    background: var(--color-brand-50);
    border-color: var(--color-brand-300);
  }

  /* Footer */
  .ssa-footer {
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .ssa-back-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-brand-600);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .ssa-back-link:hover { color: var(--color-brand-800); }
</style>
