---
/**
 * FaqAccordion.astro
 * Accordion FAQ section with FAQPage JSON-LD schema.
 */

import type { FaqItem } from '../../lib/data';
import config from '../../site.config';

interface Props {
  faqs: FaqItem[];
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  includeSchema?: boolean;
}

const {
  faqs,
  eyebrow = 'FAQ',
  title = 'Frequently Asked Questions',
  subtitle,
  includeSchema = true,
} = Astro.props;

const faqSchema = includeSchema && faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map(faq => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }
  : null;
---

{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

<section class="section faq-section">
  <div class="container">
    <div class="faq-layout">
      <header class="faq-header">
        {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
        {title   && <h2 class="section-title">{title}</h2>}
        {subtitle && <p class="section-subtitle">{subtitle}</p>}
        <a href="/contact/" class="btn btn-primary" style="margin-top: var(--space-6)">
          Ask Us Anything
        </a>
      </header>

      <div class="faq-list" id="faq-list">
        {faqs.map((faq, i) => (
          <div class="faq-item" id={`faq-${i}`}>
            <button
              class="faq-question"
              aria-expanded="false"
              aria-controls={`faq-answer-${i}`}
              id={`faq-btn-${i}`}
            >
              <span>{faq.question}</span>
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <div
              class="faq-answer"
              id={`faq-answer-${i}`}
              role="region"
              aria-labelledby={`faq-btn-${i}`}
              hidden
            >
              <div class="faq-answer-inner">
                <p>{faq.answer}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-layout {
    display: grid;
    gap: var(--space-12);
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .faq-layout {
      grid-template-columns: 1fr 2fr;
      align-items: start;
    }
  }

  .faq-header { position: sticky; top: calc(var(--header-height) + var(--space-8)); }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item:last-child { border-bottom: none; }

  .faq-question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    text-align: left;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    background: none;
    border: none;
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .faq-question:hover {
    background: var(--color-bg-subtle);
    color: var(--color-brand-700);
  }

  .faq-question[aria-expanded="true"] {
    color: var(--color-brand-700);
    background: var(--color-brand-50);
  }

  .faq-icon {
    flex-shrink: 0;
    transition: transform var(--transition-fast);
    color: var(--color-text-muted);
  }

  .faq-question[aria-expanded="true"] .faq-icon {
    transform: rotate(180deg);
    color: var(--color-brand-600);
  }

  .faq-answer {
    overflow: hidden;
  }

  .faq-answer-inner {
    padding: var(--space-2) var(--space-6) var(--space-5);
  }

  .faq-answer-inner p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.faq-question');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls')!;
      const answer   = document.getElementById(answerId)!;

      // Close all others
      buttons.forEach(b => {
        if (b !== btn) {
          b.setAttribute('aria-expanded', 'false');
          const a = document.getElementById(b.getAttribute('aria-controls')!)!;
          a.hidden = true;
        }
      });

      btn.setAttribute('aria-expanded', String(!expanded));
      answer.hidden = expanded;
    });
  });
</script>
