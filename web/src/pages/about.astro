---
/**
 * pages/about.astro — About page
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Testimonials from '../components/blocks/Testimonials.astro';
import TrustBar from '../components/blocks/TrustBar.astro';
import CtaBanner from '../components/blocks/CtaBanner.astro';
import { getBusiness, getTestimonials } from '../lib/data';
import config from '@/site.config';
import { contactUrl, servicesUrl } from '../lib/urls';

const business     = await getBusiness();
const testimonials = await getTestimonials(3);

const yearsInBusiness = business.yearEstablished
  ? new Date().getFullYear() - business.yearEstablished
  : null;

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': config.schemaType,
  name: business.name,
  foundingDate: business.yearEstablished ? String(business.yearEstablished) : undefined,
  founder: business.owner ? { '@type': 'Person', name: business.owner } : undefined,
  description: business.description,
  telephone: business.phone,
  url: config.siteUrl,
};
---

<BaseLayout seo={{
  title: `About ${business.name}`,
  description: `Learn about ${business.name} — ${business.description} Serving ${business.address.city}, ${business.address.state} since ${business.yearEstablished || 'day one'}.`,
  schema: aboutSchema,
  breadcrumbs: [{ name: 'About', url: '/about/' }],
}}>

  <!-- Page hero -->
  <div class="page-hero">
    <div class="container">
      <p class="section-eyebrow">Our Story</p>
      <h1 class="section-title">Built on Reputation.<br/>Proven by Our Work.</h1>
      <p class="section-subtitle">
        Since {business.yearEstablished || '2015'}, JP Construction has built a reputation on quality craftsmanship,
        reliable timelines, and results that speak for themselves. No excuses. Just solid work done right.
      </p>
      <div class="hero-actions">
        <a href={contactUrl()} class="btn btn-primary btn-lg">Get an Estimate</a>
        <a href={servicesUrl()} class="btn btn-ghost-light btn-lg">Our Services</a>
      </div>
    </div>
  </div>

  <!-- Trust bar -->
  <TrustBar variant="light">
    <li class="trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
      </svg>
      Free Estimates — No Pressure, No Obligation
    </li>
    <li class="trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Family-Owned & Operated
    </li>
    <li class="trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      Licensed & Fully Insured
    </li>
    <li class="trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
      </svg>
      Dedicated Project Management
    </li>
  </TrustBar>

  <!-- Meet the Owners -->
  <section class="section owners-section">
    <div class="container">
      <div class="owners-grid">

        <div class="owners-text">
          <p class="section-eyebrow">The People Behind the Work</p>
          <h2 class="owners-title">A family business built on craftsmanship and accountability.</h2>
          <p class="owners-bio">
            JP Construction is a family-owned business built on a straightforward premise: when you hire us,
            you get a team that treats your project with the same care they'd bring to their own home.
            Founded in {business.yearEstablished || '2015'}, we've built our reputation one project at a time
            — through quality work, honest communication, and results that hold up long after we're gone.
          </p>
          <p class="owners-bio">
            That accountability isn't just a selling point. It means consistent standards at every stage,
            from the first site visit through final walkthrough. Every material choice, every subcontractor,
            every schedule decision reflects the standard this company was built on.
          </p>
        </div>

        <div class="owners-image-col">
          <div class="owners-image-wrap">
            <img
              src="https://images.unsplash.com/photo-1568992687947-868a62a9f521?w=800&q=80&auto=format&fit=crop"
              alt="JP Construction crew on a job site in Westmoreland County, PA"
              loading="lazy"
              width="800"
              height="1000"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- What Sets Us Apart -->
  <section class="section why-section">
    <div class="container">
      <header class="why-header-centered">
        <p class="section-eyebrow">Why JP Construction</p>
        <h2 class="section-title">What Sets Us Apart</h2>
      </header>

      <ul class="why-grid" role="list">
        {[
          {
            icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
            title: 'Licensed & Fully Insured',
            body: 'Every job is covered. We carry full general liability and workers\' comp — so your home and your investment are protected from day one.',
          },
          {
            icon: `<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
            title: 'Honest, Itemized Estimates',
            body: 'No vague quotes. No bait-and-switch. You get a clear, line-item estimate before any work begins — and we stick to it.',
          },
          {
            icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
            title: 'On-Time, Every Time',
            body: 'We schedule carefully and staff appropriately. If something changes, you hear it from us first — before you notice it yourself.',
          },
          {
            icon: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
            title: 'Dedicated Project Management',
            body: 'Every project has a consistent point of contact from first site visit through final walkthrough. You always know who to call — and they always know where your project stands.',
          },
          {
            icon: `<polyline points="20 6 9 17 4 12"/>`,
            title: 'Satisfaction Guaranteed',
            body: 'We don\'t consider a job done until you\'re genuinely satisfied. If something\'s not right, we fix it. No arguments, no invoices.',
          },
          {
            icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
            title: 'Rooted in This Community',
            body: `${yearsInBusiness ? yearsInBusiness + '+ years' : 'Years'} in Westmoreland County. We live here. We build here. Our reputation is on the line on every street we work.`,
          },
        ].map(item => (
          <li class="why-card">
            <div class="why-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={item.icon} />
            </div>
            <h3 class="why-card-title">{item.title}</h3>
            <p class="why-card-body">{item.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Testimonials -->
  {testimonials.length > 0 && (
    <Testimonials testimonials={testimonials} businessName={business.name} />
  )}

  <!-- Standard bottom CTA -->
  <CtaBanner
    headline={`Start Your Project with ${business.name}`}
    subheadline="Get your free estimate today. No pressure, no obligation."
    primaryCta={{ label: 'Get an Estimate', href: '/contact/' }}
    phone={business.phone}
    phoneHref={business.phoneHref}
    variant="brand"
  />

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────────────── */
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: var(--space-24) 0 var(--space-20);
    background-color: var(--color-brand-900);
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=1600&q=80&auto=format&fit=crop');
    background-size: cover;
    background-position: center 35%;
  }

  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(10,10,10,0.88) 0%, rgba(10,10,10,0.68) 55%, rgba(10,10,10,0.35) 100%),
      linear-gradient(to top, rgba(10,10,10,0.55) 0%, transparent 50%);
  }

  .page-hero .container { position: relative; z-index: 1; }
  .page-hero .section-eyebrow { color: var(--color-accent-500); }

  .page-hero .section-title {
    color: #fff;
    margin-top: var(--space-2);
    max-width: 620px;
  }

  .page-hero .section-subtitle {
    color: rgba(255,255,255,0.70);
    margin-top: var(--space-4);
    max-width: 560px;
    font-size: var(--text-lg);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .btn-ghost-light {
    color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.30);
    background: transparent;
  }

  .btn-ghost-light:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.08);
  }

  /* ── Trust bar items ───────────────────────────────────────────────────────── */
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
  }

  .trust-item svg { color: var(--color-accent-500); flex-shrink: 0; }

  /* ── Meet the Owners ───────────────────────────────────────────────────────── */
  .owners-section {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .owners-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 768px) {
    .owners-grid {
      grid-template-columns: 55fr 45fr;
      gap: var(--space-16);
    }
  }

  .owners-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.15;
    margin: var(--space-3) 0 var(--space-5);
  }

  .owners-bio {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin: 0 0 var(--space-5);
  }

  .owners-image-wrap {
    position: relative;
    min-height: 400px;
    border-radius: var(--radius-2xl);
    overflow: hidden;
  }

  .owners-image-wrap img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Why section ───────────────────────────────────────────────────────────── */
  .why-section { background: var(--color-bg-subtle); }

  .why-header-centered {
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .why-header-centered .section-eyebrow { justify-content: center; }

  .why-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px)  { .why-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .why-grid { grid-template-columns: repeat(3, 1fr); } }

  .why-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .why-card:hover {
    border-color: var(--color-brand-200);
    box-shadow: var(--shadow-md);
  }

  .why-card-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-lg);
    background: var(--color-brand-100);
    color: var(--color-brand-700);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4);
    flex-shrink: 0;
  }

  .why-card-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    line-height: 1.3;
  }

  .why-card-body {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }
</style>