# ─── Sanity ───────────────────────────────────────────────────────────────────
# Required when cmsMode = 'sanity' in site.config.ts
# Find these in your Sanity project dashboard: manage.sanity.io

SANITY_PROJECT_ID=your_project_id_here
SANITY_DATASET=production

# Sanity Studio (used by /studio)
SANITY_STUDIO_PROJECT_ID=your_project_id_here
SANITY_STUDIO_DATASET=production

# ─── Optional integrations ────────────────────────────────────────────────────
# Google Maps API key (for GoogleMapsEmbed component)
# PUBLIC_ prefix makes it available in the browser
PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Analytics 4 (can also be set in site.config.ts)
PUBLIC_GA4_ID=

# HubSpot portal ID (for HubSpot form embed, if used)
PUBLIC_HUBSPOT_PORTAL_ID=
