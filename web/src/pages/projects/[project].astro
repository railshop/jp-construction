---
/**
 * pages/projects/[project].astro — Individual project page
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import BeforeAfterSlider from '../../components/blocks/BeforeAfterSlider.astro';
import CtaBanner from '../../components/blocks/CtaBanner.astro';
import { getBusiness, getProjects } from '../../lib/data';
import config from '../../site.config';

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map(p => ({ params: { project: p.slug } }));
}

const { project: projectSlug } = Astro.params;
const business = await getBusiness();
const projects = await getProjects();
const project  = projects.find(p => p.slug === projectSlug)!;

const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.title,
  description: project.description,
  creator: { '@type': 'Organization', name: business.name },
  ...(project.completedDate && { dateCreated: project.completedDate }),
  ...(project.images[0] && { image: project.images[0] }),
};
import { homeUrl, aboutUrl, contactUrl, servicesUrl, areasUrl, blogUrl, projectsUrl, serviceUrl, areaUrl, comboUrl, blogPostUrl, projectUrl } from '../../lib/urls';
---

<BaseLayout seo={{
  title: project.title,
  description: project.description,
  ogImage: project.images[0],
  schema: projectSchema,
  breadcrumbs: [
    { name: 'Projects', url: '/projects/' },
    { name: project.title, url: `/projects/${project.slug}/` },
  ],
}}>

  <!-- Project header -->
  <div class="project-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={homeUrl()}>Home</a>
        <span aria-hidden="true">/</span>
        <a href={projectsUrl()}>Projects</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{project.title}</span>
      </nav>

      <div class="project-header-grid">
        <div>
          <p class="project-category-label">{project.category}</p>
          <h1 class="project-title">{project.title}</h1>
          <p class="project-desc">{project.description}</p>
        </div>

        <aside class="project-facts">
          {project.location && (
            <div class="project-fact">
              <span class="project-fact-label">Location</span>
              <span class="project-fact-value">{project.location}</span>
            </div>
          )}
          {project.completedDate && (
            <div class="project-fact">
              <span class="project-fact-label">Completed</span>
              <span class="project-fact-value">{new Date(project.completedDate).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span>
            </div>
          )}
          {project.category && (
            <div class="project-fact">
              <span class="project-fact-label">Category</span>
              <span class="project-fact-value">{project.category}</span>
            </div>
          )}
          <a href={contactUrl()} class="btn btn-primary" style="width:100%; justify-content:center; margin-top:var(--space-5);">
            Start a Similar Project
          </a>
        </aside>
      </div>
    </div>
  </div>

  <!-- Project images -->
  {project.images.length > 0 && (
    <section class="section-sm project-images">
      <div class="container">
        <div class="project-images-grid">
          {project.images.map((img, i) => (
            <div class:list={['project-image-item', { 'project-image-item--featured': i === 0 }]}>
              <img src={img} alt={`${project.title} — photo ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} width="800" height="600" />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Before / After slider -->
  {config.features.beforeAfterSlider && project.beforeImage && project.afterImage && (
    <BeforeAfterSlider
      items={[{ before: project.beforeImage, after: project.afterImage, caption: project.title }]}
      eyebrow="Transformation"
      title="Before & After"
    />
  )}

  <!-- Testimonial -->
  {project.testimonial && (
    <section class="section-sm project-testimonial-section">
      <div class="container">
        <blockquote class="project-testimonial">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <p class="project-testimonial-text">{project.testimonial}</p>
          {project.testimonialAuthor && (
            <footer class="project-testimonial-author">— {project.testimonialAuthor}</footer>
          )}
        </blockquote>
      </div>
    </section>
  )}

  <!-- More projects -->
  {projects.filter(p => p.slug !== project.slug).length > 0 && (
    <section class="section more-projects">
      <div class="container">
        <h2 class="more-projects-title">More Projects</h2>
        <ul class="more-projects-grid" role="list">
          {projects.filter(p => p.slug !== project.slug).slice(0, 3).map(p => (
            <li>
              <a href={`/projects/${p.slug}/`} class="more-project-card">
                {p.images[0] && (
                  <div class="more-project-image">
                    <img src={p.images[0]} alt={p.title} loading="lazy" width="400" height="300" />
                  </div>
                )}
                <div class="more-project-body">
                  <p class="more-project-category">{p.category}</p>
                  <h3 class="more-project-title">{p.title}</h3>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <CtaBanner
    headline="Ready to Start Your Project?"
    subheadline={`Get your free estimate from ${business.name} today.`}
    primaryCta={{ label: 'Get a Free Quote', href: '/contact/' }}
    phone={business.phone}
    phoneHref={business.phoneHref}
    variant="brand"
  />
</BaseLayout>

<style>
  .project-header { background: var(--color-bg-subtle); border-bottom: 1px solid var(--color-border); padding: var(--space-10) 0 var(--space-12); }

  .breadcrumb { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); color: var(--color-text-subtle); margin-bottom: var(--space-8); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-brand-600); }

  .project-header-grid { display: grid; gap: var(--space-10); grid-template-columns: 1fr; }
  @media (min-width: 1024px) { .project-header-grid { grid-template-columns: 1fr 280px; align-items: start; } }

  .project-category-label { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand-600); margin: 0 0 var(--space-3); }

  .project-title { font-family: var(--font-display); font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl)); font-weight: 800; line-height: 1.1; margin: 0 0 var(--space-4); }

  .project-desc { font-size: var(--text-lg); color: var(--color-text-muted); line-height: 1.7; margin: 0; max-width: 600px; }

  .project-facts { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-6); }

  .project-fact { display: flex; justify-content: space-between; gap: var(--space-4); padding-block: var(--space-3); border-bottom: 1px solid var(--color-border); font-size: var(--text-sm); }
  .project-fact:last-of-type { border-bottom: none; }
  .project-fact-label { color: var(--color-text-muted); }
  .project-fact-value { font-weight: 600; }

  .project-images-grid { display: grid; gap: var(--space-4); grid-template-columns: 1fr; }
  @media (min-width: 640px) { .project-images-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .project-images-grid { grid-template-columns: repeat(3, 1fr); } }

  .project-image-item { border-radius: var(--radius-xl); overflow: hidden; aspect-ratio: 4/3; }
  .project-image-item--featured { grid-column: 1 / -1; aspect-ratio: 16/7; }
  .project-image-item img { width: 100%; height: 100%; object-fit: cover; }

  .project-testimonial-section { background: var(--color-brand-50); border-block: 1px solid var(--color-brand-100); }

  .project-testimonial { max-width: 700px; margin-inline: auto; text-align: center; }
  .project-testimonial svg { color: var(--color-brand-200); margin-bottom: var(--space-4); }
  .project-testimonial-text { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 500; font-style: italic; color: var(--color-brand-900); line-height: 1.5; margin: 0 0 var(--space-4); }
  .project-testimonial-author { font-size: var(--text-sm); font-weight: 600; color: var(--color-brand-700); }

  .more-projects-title { font-family: var(--font-body); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-muted); margin: 0 0 var(--space-6); }

  .more-projects-grid { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }

  .more-project-card { display: block; text-decoration: none; border-radius: var(--radius-xl); overflow: hidden; border: 1px solid var(--color-border); transition: box-shadow var(--transition-base), transform var(--transition-base); }
  .more-project-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
  .more-project-image { aspect-ratio: 4/3; overflow: hidden; }
  .more-project-image img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--transition-slow); }
  .more-project-card:hover .more-project-image img { transform: scale(1.04); }
  .more-project-body { padding: var(--space-4) var(--space-5); background: var(--color-bg); }
  .more-project-category { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-brand-600); margin: 0 0 var(--space-1); }
  .more-project-title { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; margin: 0; }
</style>
