---
/**
 * FeaturedProjects.astro
 *
 * Homepage project showcase. Editorial grid on a dark background.
 *
 * Layout: one full-width hero card on top, two equal cards below.
 * All cards are full-bleed photography with gradient overlays — consistent
 * visual language throughout. Compact vertical footprint.
 *
 * Use on homepage only. For the full portfolio, use ProjectGallery.astro.
 */

import type { Project } from '../../lib/data';

interface Props {
  projects: Project[];
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  viewAllHref?: string;
}

const {
  projects,
  eyebrow = 'Our Work',
  title = 'Built to Show For',
  subtitle,
  viewAllHref = '/projects/',
} = Astro.props;

const featured  = projects.find(p => p.featured) ?? projects[0];
const duocards  = projects.filter(p => p.slug !== featured?.slug).slice(0, 2);
---

{projects.length > 0 && (
<section class="section fp-section">
  <div class="container">

    <!-- Section header -->
    <div class="fp-header">
      <div class="fp-header-text">
        {eyebrow && <p class="section-eyebrow fp-eyebrow">{eyebrow}</p>}
        {title && <h2 class="section-title fp-title">{title}</h2>}
        {subtitle && <p class="fp-subtitle">{subtitle}</p>}
      </div>
      <a href={viewAllHref} class="btn btn-ghost btn-sm" aria-label="View all projects">
        View All Projects
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

    {featured && (
      <div class="fp-showcase">

        <!-- Hero — full width, tall -->
        <a href={`/projects/${featured.slug}/`} class="fp-hero animate-fade-up" style="animation-delay: 0ms">
          <div class="fp-img">
            {featured.images[0]
              ? <img src={featured.images[0]} alt={featured.title} loading="eager" decoding="async" width="1200" height="600" />
              : <div class="fp-placeholder" aria-hidden="true"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
            }
          </div>
          <div class="fp-overlay" aria-hidden="true"></div>
          <div class="fp-body">
            <p class="fp-category">{featured.category}</p>
            <h3 class="fp-hero-title">{featured.title}</h3>
            {featured.location && (
              <p class="fp-location">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {featured.location}
              </p>
            )}
            <span class="fp-cta" aria-hidden="true">
              View Project
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </a>

        <!-- Duo — two equal cards -->
        {duocards.length > 0 && (
          <div class="fp-duo">
            {duocards.map((project, i) => (
              <a
                href={`/projects/${project.slug}/`}
                class="fp-card animate-fade-up"
                style={`animation-delay: ${(i + 1) * 120}ms`}
              >
                <div class="fp-img">
                  {project.images[0]
                    ? <img src={project.images[0]} alt={project.title} loading="lazy" decoding="async" width="600" height="450" />
                    : <div class="fp-placeholder" aria-hidden="true"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
                  }
                </div>
                <div class="fp-overlay" aria-hidden="true"></div>
                <div class="fp-body">
                  <p class="fp-category">{project.category}</p>
                  <h3 class="fp-card-title">{project.title}</h3>
                  {project.location && (
                    <p class="fp-location">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                      {project.location}
                    </p>
                  )}
                  <span class="fp-cta" aria-hidden="true">
                    View Project
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        )}

      </div>
    )}

  </div>
</section>
)}

<style>
  /* ─── Section ─────────────────────────────────────────────────────────────── */

  .fp-section {
    background: var(--color-brand-950);
  }

  /* ─── Header ─────────────────────────────────────────────────────────────── */

  .fp-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
  }

  .fp-eyebrow { justify-content: flex-start; }

  .fp-section .section-eyebrow { color: var(--color-accent-500); }

  .fp-title {
    color: #ffffff;
    margin-bottom: 0;
  }

  .fp-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.5);
    margin: var(--space-2) 0 0;
    max-width: 480px;
  }

  .fp-header .btn {
    flex-shrink: 0;
    align-self: flex-end;
  }

  /* ─── Showcase layout ─────────────────────────────────────────────────────── */

  .fp-showcase {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* Duo: two equal cards side by side */
  .fp-duo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  /* ─── Shared: full-bleed card base ───────────────────────────────────────── */

  .fp-hero,
  .fp-card {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-brand-900);
    opacity: 0;
    animation-fill-mode: forwards;
  }

  /* Hero: wide cinematic proportions */
  .fp-hero {
    aspect-ratio: 16 / 7;
    min-height: 240px;
  }

  /* Duo cards: 4:3 */
  .fp-card {
    aspect-ratio: 4 / 3;
  }

  /* ─── Image layer ─────────────────────────────────────────────────────────── */

  .fp-img {
    position: absolute;
    inset: 0;
  }

  .fp-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.65s ease;
  }

  .fp-hero:hover .fp-img img,
  .fp-card:hover .fp-img img {
    transform: scale(1.04);
  }

  /* ─── Gradient overlay ────────────────────────────────────────────────────── */

  .fp-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 10, 10, 0.90) 0%,
      rgba(10, 10, 10, 0.35) 45%,
      rgba(10, 10, 10, 0.06) 100%
    );
    transition: opacity var(--transition-base);
  }

  .fp-hero:hover .fp-overlay,
  .fp-card:hover .fp-overlay {
    opacity: 0.82;
  }

  /* ─── Text body (absolute, bottom of each card) ──────────────────────────── */

  .fp-body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .fp-card .fp-body {
    padding: var(--space-4) var(--space-5);
  }

  /* ─── Typography ─────────────────────────────────────────────────────────── */

  .fp-category {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent-400);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    line-height: 1;
  }

  .fp-hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .fp-card-title {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.8vw, 1.25rem);
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .fp-location {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }

  /* "View Project" CTA — reveals on hover */
  .fp-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1.5px solid var(--color-accent-500);
    padding-bottom: 2px;
    width: fit-content;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity var(--transition-base), transform var(--transition-base);
  }

  .fp-hero:hover .fp-cta,
  .fp-card:hover .fp-cta {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Placeholder (no image) ─────────────────────────────────────────────── */

  .fp-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.12);
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  /* ─── Mobile: stack all cards, move text below image ──────────────────────── */

  @media (max-width: 767px) {
    /* Single column for duo */
    .fp-duo {
      grid-template-columns: 1fr;
    }

    /* Reset both hero and card from full-bleed overlay to stacked layout */
    .fp-hero,
    .fp-card {
      aspect-ratio: unset;
      display: flex;
      flex-direction: column;
    }

    /* Image becomes a natural-flow element with fixed height */
    .fp-hero .fp-img {
      position: relative;
      height: 240px;
      flex-shrink: 0;
    }

    .fp-card .fp-img {
      position: relative;
      height: 220px;
      flex-shrink: 0;
    }

    /* Hide the dark gradient overlay — text is below the image now */
    .fp-hero .fp-overlay,
    .fp-card .fp-overlay {
      display: none;
    }

    /* Text sits below the image in a dark panel */
    .fp-hero .fp-body,
    .fp-card .fp-body {
      position: static;
      padding: var(--space-4) var(--space-5);
      background: var(--color-brand-900);
      border-radius: 0 0 var(--radius-lg) var(--radius-lg);
      gap: var(--space-2);
    }

    /* Match hero title size to card titles on mobile */
    .fp-hero-title {
      font-size: clamp(0.95rem, 1.8vw, 1.25rem);
    }

    /* Smaller category label on mobile */
    .fp-category {
      font-size: 0.65rem;
    }

    /* Always show "View Project" — no hover on mobile */
    .fp-hero .fp-cta,
    .fp-card .fp-cta {
      opacity: 1;
      transform: none;
    }
  }
</style>
