---
/**
 * GoogleMapsEmbed.astro
 * Embedded Google Map centered on business location.
 * Lazy loads for performance.
 */

import { getBusiness } from '../../lib/data';
import config from '../../site.config';

interface Props {
  zoom?: number;
  height?: string;
  showInfo?: boolean;
}

const { zoom = 13, height = '400px', showInfo = true } = Astro.props;
const business = await getBusiness();

const apiKey = config.googleMapsApiKey;
const lat = business.coordinates?.lat;
const lng = business.coordinates?.lng;

const embedSrc = apiKey && lat && lng
  ? `https://www.google.com/maps/embed/v1/place?key=${apiKey}&q=${lat},${lng}&zoom=${zoom}`
  : null;

const fallbackSrc = lat && lng
  ? `https://maps.google.com/maps?q=${lat},${lng}&z=${zoom}&output=embed`
  : null;

const mapSrc = embedSrc || fallbackSrc;
---

{mapSrc && (
  <section class="map-section section-sm">
    <div class="container">
      {showInfo && (
        <div class="map-info">
          <div class="map-info-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>
              {business.address.city}, {business.address.state}
              {business.serviceRadius && ` — Serving ${business.serviceRadius}`}
            </span>
          </div>
          <div class="map-info-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.77 3.44 2 2 0 0 1 3.74 1.26h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href={business.phoneHref} class="map-phone">{business.phone}</a>
          </div>
        </div>
      )}
      <div class="map-frame-wrapper" style={`height: ${height}`}>
        <iframe
          src={mapSrc}
          class="map-frame"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Map showing ${business.name} service area`}
        ></iframe>
      </div>
    </div>
  </section>
)}

<style>
  .map-info {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-8);
    margin-bottom: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .map-info-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .map-info-item svg { color: var(--color-brand-600); flex-shrink: 0; }

  .map-phone {
    color: var(--color-brand-700);
    font-weight: 600;
    text-decoration: none;
  }

  .map-phone:hover { text-decoration: underline; }

  .map-frame-wrapper {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .map-frame { display: block; }
</style>
