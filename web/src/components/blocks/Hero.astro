---
/**
 * Hero.astro
 * Full-width hero section. Supports background image, video, or gradient.
 * Primary CTA and secondary CTA configurable per page.
 */

interface Props {
  headline: string;
  subheadline?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  backgroundImage?: string;
  backgroundVideo?: string;
  badge?: string;
  trustSignals?: string[];
  variant?: 'default' | 'centered' | 'split';
}

const {
  headline,
  subheadline,
  primaryCta = { label: 'Get a Free Quote', href: '/contact/' },
  secondaryCta,
  backgroundImage,
  badge,
  trustSignals = [],
  variant = 'default',
} = Astro.props;
---

<section
  class:list={['hero', `hero--${variant}`]}
  style={backgroundImage ? `--hero-bg: url('${backgroundImage}')` : ''}
>
  {backgroundImage && <div class="hero-bg-overlay" aria-hidden="true"></div>}

  <div class="container">
    <div class="hero-content">
      {badge && (
        <div class="hero-badge animate-fade-up">
          <span class="badge badge-brand">{badge}</span>
        </div>
      )}

      <h1 class="hero-headline animate-fade-up delay-100" set:html={headline} />

      {subheadline && (
        <p class="hero-subheadline animate-fade-up delay-200">{subheadline}</p>
      )}

      <div class="hero-actions animate-fade-up delay-300">
        <a href={primaryCta.href} class="btn btn-primary btn-lg">
          {primaryCta.label}
        </a>
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn-ghost btn-lg">
            {secondaryCta.label}
          </a>
        )}
      </div>

      {trustSignals.length > 0 && (
        <ul class="hero-trust animate-fade-up delay-400" role="list">
          {trustSignals.map(signal => (
            <li class="hero-trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {signal}
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(680px, 85vh);
    display: flex;
    align-items: center;
    background-color: var(--color-brand-950);
    background-image: var(--hero-bg, none);
    background-size: cover;
    background-position: center;
    padding-top: var(--header-height);
    overflow: hidden;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-brand-950) 80%, transparent),
      color-mix(in srgb, var(--color-brand-900) 60%, transparent)
    );
  }

  .hero--centered .hero-content {
    text-align: center;
    align-items: center;
    max-width: 800px;
    margin-inline: auto;
  }

  .hero--centered .hero-subheadline,
  .hero--centered .hero-trust {
    margin-inline: auto;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-6);
    max-width: 680px;
    padding-block: var(--space-16);
  }

  .hero-badge { margin-bottom: calc(var(--space-2) * -1); }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 5.5vw, var(--text-7xl));
    font-weight: 800;
    line-height: 1.05;
    color: #ffffff;
    margin: 0;
  }

  .hero-headline :global(em) {
    font-style: normal;
    color: var(--color-accent-400);
  }

  .hero-subheadline {
    font-size: clamp(var(--text-base), 2vw, var(--text-xl));
    color: color-mix(in srgb, #ffffff 75%, transparent);
    line-height: 1.7;
    max-width: 540px;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .hero-trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-6);
  }

  .hero-trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: color-mix(in srgb, #ffffff 80%, transparent);
  }

  .hero-trust-item svg {
    color: var(--color-accent-400);
    flex-shrink: 0;
  }
</style>
