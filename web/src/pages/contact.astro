---
/**
 * pages/contact.astro — Contact page with Netlify Forms
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { getBusiness } from '../lib/data';

const business = await getBusiness();
---

<BaseLayout seo={{
  title: 'Contact Us — Get a Free Quote',
  description: `Contact ${business.name} for a free estimate. Serving ${business.address.city} and surrounding areas. Call ${business.phone} or fill out our quick form.`,
  breadcrumbs: [{ name: 'Contact', url: '/contact/' }],
}}>

  <div class="contact-page">
    <div class="container">
      <div class="contact-grid">

        <!-- Form -->
        <div class="contact-form-col">
          <header class="contact-header">
            <p class="section-eyebrow">Get in Touch</p>
            <h1 class="section-title">Request a Free Quote</h1>
            <p class="section-subtitle">
              Tell us about your project and we'll get back to you within one business day.
            </p>
          </header>

          <!-- Netlify Form -->
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="contact-form"
            id="contact-form"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden" aria-hidden="true">
              <label>Do not fill this out: <input name="bot-field" /></label>
            </p>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="first-name">First Name <span aria-label="required">*</span></label>
                <input class="form-input" type="text" id="first-name" name="first-name" required autocomplete="given-name" />
              </div>
              <div class="form-group">
                <label class="form-label" for="last-name">Last Name <span aria-label="required">*</span></label>
                <input class="form-input" type="text" id="last-name" name="last-name" required autocomplete="family-name" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="email">Email <span aria-label="required">*</span></label>
                <input class="form-input" type="email" id="email" name="email" required autocomplete="email" />
              </div>
              <div class="form-group">
                <label class="form-label" for="phone">Phone</label>
                <input class="form-input" type="tel" id="phone" name="phone" autocomplete="tel" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="service">Service Needed</label>
              <select class="form-select" id="service" name="service">
                <option value="">Select a service...</option>
                <slot name="service-options" />
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="message">Tell Us About Your Project <span aria-label="required">*</span></label>
              <textarea
                class="form-textarea"
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Describe your project, timeline, and any specific requirements..."
              ></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="address">Property Address (Optional)</label>
              <input class="form-input" type="text" id="address" name="address" autocomplete="street-address" placeholder="123 Main St, City, State" />
            </div>

            <div class="form-group form-checkbox">
              <input type="checkbox" id="consent" name="consent" required />
              <label for="consent" class="form-label-inline">
                I agree to be contacted by {business.name} regarding my request.
              </label>
            </div>

            <button type="submit" class="btn btn-primary btn-lg form-submit">
              Send My Request
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </button>
          </form>

          <div class="form-success hidden" id="form-success" role="status" aria-live="polite">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <h2>Thank You!</h2>
            <p>We received your request and will follow up within one business day.</p>
          </div>
        </div>

        <!-- Contact info sidebar -->
        <aside class="contact-info-col">
          <div class="contact-info-card">
            <h2 class="contact-info-title">Contact Information</h2>

            <div class="contact-info-items">
              <div class="contact-info-item">
                <div class="contact-info-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.77 3.44 2 2 0 0 1 3.74 1.26h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </div>
                <div>
                  <p class="contact-info-label">Phone</p>
                  <a href={business.phoneHref} class="contact-info-value contact-info-link">{business.phone}</a>
                </div>
              </div>

              <div class="contact-info-item">
                <div class="contact-info-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                </div>
                <div>
                  <p class="contact-info-label">Email</p>
                  <a href={`mailto:${business.email}`} class="contact-info-value contact-info-link">{business.email}</a>
                </div>
              </div>

              {business.address.city && (
                <div class="contact-info-item">
                  <div class="contact-info-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                      <circle cx="12" cy="10" r="3"/>
                    </svg>
                  </div>
                  <div>
                    <p class="contact-info-label">Service Area</p>
                    <p class="contact-info-value">{business.serviceRadius || `${business.address.city}, ${business.address.state}`}</p>
                  </div>
                </div>
              )}
            </div>

            <div class="contact-hours">
              <h3 class="contact-hours-title">Business Hours</h3>
              {business.hours.map(h => (
                <div class="hours-row">
                  <span class="hours-days">{h.days}</span>
                  <span class="hours-time">{h.hours}</span>
                </div>
              ))}
            </div>

            {business.license && (
              <p class="contact-license">{business.license} &bull; Fully Insured</p>
            )}
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page { padding-block: var(--space-16); }

  .contact-grid {
    display: grid;
    gap: var(--space-12);
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .contact-grid { grid-template-columns: 1fr 340px; align-items: start; }
  }

  .contact-header { margin-bottom: var(--space-10); }

  .contact-form { display: flex; flex-direction: column; gap: var(--space-5); }

  .form-row {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .form-row { grid-template-columns: 1fr 1fr; }
  }

  .form-checkbox {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .form-checkbox input[type="checkbox"] {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--color-brand-600);
    cursor: pointer;
  }

  .form-label-inline {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    cursor: pointer;
  }

  .form-submit { align-self: flex-start; }

  .hidden { display: none !important; }

  .form-success {
    text-align: center;
    padding: var(--space-12);
    background: var(--color-brand-50);
    border: 1px solid var(--color-brand-200);
    border-radius: var(--radius-xl);
    color: var(--color-brand-700);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .form-success h2 { color: var(--color-brand-800); margin: 0; }
  .form-success p  { color: var(--color-brand-700); margin: 0; }

  /* Contact info card */
  .contact-info-card {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    position: sticky;
    top: calc(var(--header-height) + var(--space-8));
  }

  .contact-info-title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-5);
  }

  .contact-info-items { display: flex; flex-direction: column; gap: var(--space-5); margin-bottom: var(--space-6); }

  .contact-info-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .contact-info-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-lg);
    background: var(--color-brand-100);
    color: var(--color-brand-700);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-info-label {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--space-1);
  }

  .contact-info-value {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
  }

  .contact-info-link { text-decoration: none; color: var(--color-brand-700); }
  .contact-info-link:hover { text-decoration: underline; }

  .contact-hours {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-5);
    margin-bottom: var(--space-5);
  }

  .contact-hours-title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    font-size: var(--text-sm);
    padding-block: var(--space-1);
  }

  .hours-days { color: var(--color-text); font-weight: 500; }
  .hours-time { color: var(--color-text-muted); }

  .contact-license {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    text-align: center;
    margin: 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }
</style>

<script>
  // Basic client-side success state after Netlify submission
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  if (form && success) {
    // If redirected back with ?success=true
    if (window.location.search.includes('success=true')) {
      form.classList.add('hidden');
      success.classList.remove('hidden');
    }
  }
</script>
