---
/**
 * ServiceCardsGrid.astro
 * Grid of service cards. Accepts services from the data layer.
 */

import type { Service } from '../../lib/data';

interface Props {
  services: Service[];
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  columns?: 2 | 3 | 4;
  showPricing?: boolean;
}

const {
  services,
  eyebrow = 'What We Do',
  title = 'Our Services',
  subtitle,
  columns = 3,
  showPricing = false,
} = Astro.props;
---

<section class="section services-grid-section">
  <div class="container">
    {(eyebrow || title || subtitle) && (
      <header class="section-header">
        {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
        {title   && <h2 class="section-title">{title}</h2>}
        {subtitle && <p class="section-subtitle">{subtitle}</p>}
      </header>
    )}

    <ul
      class:list={['services-grid', `services-grid--cols-${columns}`]}
      role="list"
    >
      {services.map((service, i) => (
        <li>
          <a
            href={`/services/${service.slug}/`}
            class="service-card animate-fade-up"
            style={`animation-delay: ${i * 80}ms`}
          >
            {service.image && (
              <div class="service-card-image">
                <img
                  src={service.image}
                  alt={service.name}
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="250"
                />
              </div>
            )}
            <div class="service-card-body">
              <div class="service-card-header">
                <h3 class="service-card-title">{service.name}</h3>
                {service.emergency && (
                  <span class="badge badge-accent" aria-label="Available 24/7">24/7</span>
                )}
              </div>
              <p class="service-card-desc">{service.shortDescription}</p>
              {showPricing && service.priceRange && (
                <p class="service-card-price">
                  Starting from ${service.priceRange.min.toLocaleString()}
                </p>
              )}
              <span class="service-card-cta" aria-hidden="true">
                Learn More
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <div class="services-grid-cta">
      <a href="/services/" class="btn btn-secondary">View All Services</a>
    </div>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
    max-width: 640px;
    margin-inline: auto;
  }

  .section-header .section-subtitle {
    margin-inline: auto;
  }

  .services-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .services-grid--cols-2,
    .services-grid--cols-3,
    .services-grid--cols-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .services-grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
    .services-grid--cols-4 { grid-template-columns: repeat(4, 1fr); }
  }

  .service-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow var(--transition-base), transform var(--transition-base), border-color var(--transition-base);
    opacity: 0;
    animation-fill-mode: forwards;
  }

  .service-card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
    border-color: var(--color-brand-200);
  }

  .service-card-image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-bg-muted);
  }

  .service-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .service-card:hover .service-card-image img {
    transform: scale(1.04);
  }

  .service-card-body {
    padding: var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .service-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .service-card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .service-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .service-card-price {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-brand-700);
    margin: 0;
  }

  .service-card-cta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-brand-600);
    margin-top: auto;
    padding-top: var(--space-2);
    transition: gap var(--transition-fast);
  }

  .service-card:hover .service-card-cta { gap: var(--space-3); }

  .services-grid-cta {
    text-align: center;
    margin-top: var(--space-10);
  }
</style>
