---
/**
 * StatsBar.astro
 */

interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
  variant?: 'light' | 'dark' | 'brand';
}

const { stats, variant = 'dark' } = Astro.props;
---

<div class:list={['stats-bar', `stats-bar--${variant}`]}>
  <div class="container">
    <ul class="stats-list" role="list">
      {stats.map(stat => (
        <li class="stat-item">
          <span class="stat-value">{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .stats-bar { padding-block: var(--space-10); }
  .stats-bar--dark   { background: var(--color-neutral-900); }
  .stats-bar--brand  { background: var(--color-brand-700); }
  .stats-bar--light  { background: var(--color-bg-subtle); border-block: 1px solid var(--color-border); }

  .stats-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
    text-align: center;
  }

  @media (min-width: 768px) {
    .stats-list { grid-template-columns: repeat(4, 1fr); }
  }

  .stat-item { display: flex; flex-direction: column; gap: var(--space-1); }

  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: 800;
    color: #ffffff;
    line-height: 1;
  }

  .stats-bar--light .stat-value { color: var(--color-brand-700); }

  .stat-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: color-mix(in srgb, #ffffff 60%, transparent);
  }

  .stats-bar--light .stat-label { color: var(--color-text-muted); }
</style>
