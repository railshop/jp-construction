---
/**
 * AwardsCertifications.astro
 * Logos/badges for BBB, licensing, manufacturer certs, associations.
 */

interface Award {
  name: string;
  logo?: string;
  description?: string;
}

interface Props {
  awards: Award[];
  eyebrow?: string;
  title?: string;
  variant?: 'light' | 'muted';
}

const {
  awards,
  eyebrow = 'Trusted & Certified',
  title = 'Our Credentials',
  variant = 'muted',
} = Astro.props;
---

<section class:list={['section-sm awards-section', `awards-section--${variant}`]}>
  <div class="container">
    {(eyebrow || title) && (
      <header class="awards-header">
        {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
        {title   && <h2 class="awards-title">{title}</h2>}
      </header>
    )}
    <ul class="awards-list" role="list">
      {awards.map(award => (
        <li class="award-item">
          {award.logo
            ? <img src={award.logo} alt={award.name} class="award-logo" width="120" height="60" loading="lazy" />
            : <div class="award-badge">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <circle cx="12" cy="8" r="7"/>
                  <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
                </svg>
                <span class="award-name">{award.name}</span>
              </div>
          }
          {award.description && (
            <p class="award-desc">{award.description}</p>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .awards-section--muted { background: var(--color-bg-subtle); }

  .awards-header { text-align: center; margin-bottom: var(--space-8); }
  .awards-title {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-muted);
    margin: var(--space-2) 0 0;
  }

  .awards-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-8) var(--space-12);
  }

  .award-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    text-align: center;
  }

  .award-logo {
    max-height: 60px;
    width: auto;
    object-fit: contain;
    filter: grayscale(0.3) opacity(0.8);
    transition: filter var(--transition-base);
  }

  .award-logo:hover { filter: none; }

  .award-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-muted);
    min-width: 100px;
  }

  .award-name {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .award-desc {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    margin: 0;
    max-width: 120px;
  }
</style>
