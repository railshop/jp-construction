---
/**
 * pages/blog/index.astro — Blog listing
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/blocks/CtaBanner.astro';
import { getBusiness, getBlogPosts } from '../../lib/data';

const business = await getBusiness();
const posts    = await getBlogPosts();
const featured = posts.find(p => p.featured) || posts[0];
const rest     = posts.filter(p => p !== featured);
---

<BaseLayout seo={{
  title: `Blog — Tips, Guides & News`,
  description: `Expert tips, how-to guides, and industry news from ${business.name}. Serving ${business.address.city} and surrounding areas.`,
  breadcrumbs: [{ name: 'Blog', url: '/blog/' }],
}}>

  <div class="page-hero">
    <div class="container">
      <p class="section-eyebrow">Our Blog</p>
      <h1 class="section-title">Tips, Guides & Updates</h1>
      <p class="section-subtitle">Helpful advice from the team at {business.name}.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <p class="no-posts">No posts yet. Check back soon.</p>
      ) : (
        <div class="blog-layout">
          {featured && (
            <a href={`/blog/${featured.slug}/`} class="blog-featured">
              {featured.image && (
                <div class="blog-featured-image">
                  <img src={featured.image} alt={featured.title} loading="eager" width="800" height="450" />
                </div>
              )}
              <div class="blog-featured-body">
                <div class="blog-meta">
                  <span class="blog-category">{featured.category}</span>
                  <span class="blog-date">{new Date(featured.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                  {featured.readingTime && <span class="blog-reading-time">{featured.readingTime}</span>}
                </div>
                <h2 class="blog-featured-title">{featured.title}</h2>
                <p class="blog-featured-desc">{featured.description}</p>
                <span class="btn btn-primary">Read Article</span>
              </div>
            </a>
          )}

          {rest.length > 0 && (
            <ul class="blog-grid" role="list">
              {rest.map(post => (
                <li>
                  <a href={`/blog/${post.slug}/`} class="blog-card">
                    {post.image && (
                      <div class="blog-card-image">
                        <img src={post.image} alt={post.title} loading="lazy" width="400" height="225" />
                      </div>
                    )}
                    <div class="blog-card-body">
                      <div class="blog-meta">
                        <span class="blog-category">{post.category}</span>
                        <span class="blog-date">{new Date(post.publishDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                      </div>
                      <h3 class="blog-card-title">{post.title}</h3>
                      <p class="blog-card-desc">{post.description}</p>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      )}
    </div>
  </section>

  <CtaBanner
    headline="Ready to Get Started?"
    subheadline="Have questions? Give us a call or request a free estimate."
    primaryCta={{ label: 'Get a Free Quote', href: '/contact/' }}
    phone={business.phone}
    phoneHref={business.phoneHref}
    variant="dark"
  />
</BaseLayout>

<style>
  .page-hero { background: var(--color-bg-subtle); border-bottom: 1px solid var(--color-border); padding: var(--space-16) 0 var(--space-10); }

  .no-posts { color: var(--color-text-muted); text-align: center; padding: var(--space-16); }

  .blog-layout { display: flex; flex-direction: column; gap: var(--space-12); }

  /* Featured */
  .blog-featured {
    display: grid;
    gap: var(--space-8);
    grid-template-columns: 1fr;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow var(--transition-base);
  }

  @media (min-width: 768px) { .blog-featured { grid-template-columns: 1fr 1fr; } }

  .blog-featured:hover { box-shadow: var(--shadow-xl); }

  .blog-featured-image { aspect-ratio: 16/9; overflow: hidden; }
  .blog-featured-image img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--transition-slow); }
  .blog-featured:hover .blog-featured-image img { transform: scale(1.04); }

  .blog-featured-body {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
  }

  .blog-featured-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 2.5vw, var(--text-3xl));
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  .blog-featured-desc { font-size: var(--text-base); color: var(--color-text-muted); line-height: 1.7; margin: 0; }

  /* Meta */
  .blog-meta { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3); }

  .blog-category {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-brand-600);
    background: var(--color-brand-50);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .blog-date, .blog-reading-time {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  /* Grid */
  .blog-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px)  { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .blog-grid { grid-template-columns: repeat(3, 1fr); } }

  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .blog-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }

  .blog-card-image { aspect-ratio: 16/9; overflow: hidden; background: var(--color-bg-muted); }
  .blog-card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--transition-slow); }
  .blog-card:hover .blog-card-image img { transform: scale(1.04); }

  .blog-card-body { padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); flex: 1; }

  .blog-card-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .blog-card-desc { font-size: var(--text-sm); color: var(--color-text-muted); line-height: 1.65; margin: 0; }
</style>
